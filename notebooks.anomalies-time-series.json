ey":"WG1J7KyLMc"}],"key":"oXz9lq3lOb"},{"type":"text","value":" from the NCEP–NCAR Reanalysis ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"oICihIA8gM"},{"type":"citeGroup","kind":"parenthetical","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"cite","identifier":"kanamitsu2002ncep","label":"kanamitsu2002ncep","kind":"parenthetical","suffix":"kalnay2018ncep","position":{"start":{"line":3,"column":68},"end":{"line":3,"column":102}},"children":[{"type":"text","value":"Kanamitsu ","key":"lVuW6dk3cI"},{"type":"emphasis","children":[{"type":"text","value":"et al.","key":"uwFxARETgW"}],"key":"pEiNvwCQya"},{"type":"text","value":", 2002, kalnay2018ncep","key":"tL72DE0mH1"}],"enumerator":"1","key":"nYDo2ybrBH"}],"key":"O3KOaoRTZB"},{"type":"text","value":", stored as a preprocessed Zarr dataset on the Pythia Jetstream2 bucket.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"TmILT7CWd4"}],"key":"VDeSTBFWe9"}],"key":"j4NJtkFHmZ"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"uwind_ncep_ncar_store = s3fs.S3Map(\n    root=\"pythia/uwind-ncep-ncar.zarr\",\n    s3=fs,\n    check=False,\n)\n\nuwind_ncep_ncar = xr.open_zarr(uwind_ncep_ncar_store)\n\nuwind_850_da = (\n    uwind_ncep_ncar[\"uwnd\"]\n    .sel(level=850)\n    .drop_vars(\"level\", errors=\"ignore\")\n)\n\nuwind_ncep_ncar","key":"rJFrQenKVz"},{"type":"outputs","id":"UsGBYRQcLvVkRlt_s56FD","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":2,"metadata":{},"data":{"text/plain":{"content":"<xarray.Dataset> Size: 495MB\nDimensions:  (lat: 25, level: 2, lon: 144, time: 17167)\nCoordinates:\n  * lat      (lat) float32 100B 30.0 27.5 25.0 22.5 ... -22.5 -25.0 -27.5 -30.0\n  * level    (level) float32 8B 850.0 200.0\n  * lon      (lon) float32 576B 0.0 2.5 5.0 7.5 10.0 ... 350.0 352.5 355.0 357.5\n  * time     (time) datetime64[ns] 137kB 1979-01-01 1979-01-02 ... 2025-12-31\nData variables:\n    uwnd     (time, level, lat, lon) float32 494MB dask.array<chunksize=(1024, 2, 25, 144), meta=np.ndarray>","content_type":"text/plain"},"text/html":{"content_type":"text/html","hash":"dbb84e680efae9878c2428c481e20743","path":"/spectral-analysis-cookbook/build/dbb84e680efae9878c2428c481e20743.html"}}},"key":"jQMOJ7lGPE"}],"key":"BiugsMeBha"}],"key":"EUBz7rJYN6"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Remove the seasonal cycle","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"yTx52JGM7Y"}],"identifier":"remove-the-seasonal-cycle","label":"Remove the seasonal cycle","html_id":"remove-the-seasonal-cycle","implicit":true,"key":"jLoHsugr2L"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"We subtract the seasonal cycle at every grid point using two methods. ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"Vx9ICyE3JF"},{"type":"strong","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"Daily climatology","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"mYDVNzHKtX"}],"key":"xpJrxiK4Z8"},{"type":"text","value":" averages all values for each calendar day (Jan 1, Jan 2, …) and subtracts that mean. ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"VhidpVOia5"},{"type":"strong","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"Harmonic regression","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"rHZkdMg8Gn"}],"key":"GClxrKTrVS"},{"type":"text","value":" fits a smooth annual cycle as a sum of sine and cosine harmonics; see ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"ZtQjSZHcWj"},{"type":"link","url":"/notebooks/harmonic-anomalies","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"Remove the seasonal cycle using harmonic regression","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"UBbYTtUbAk"}],"urlSource":"./02.harmonic_anomalies.ipynb","dataUrl":"/notebooks.harmonic-anomalies.json","internal":true,"protocol":"file","key":"m5QybfRhkt"},{"type":"text","value":" for the theory and design matrix.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"mZOdkGNGcn"}],"key":"Bm4vxUuFlK"}],"key":"myzQR0ZnlF"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def remove_seasonal_cycle_daily_climatology(da, drop_feb29=True):\n    \"\"\"Remove the seasonal cycle using day-of-year climatology.\"\"\"\n    month_day = da[\"time\"].dt.strftime(\"%m-%d\")\n    da = da.assign_coords(month_day=(\"time\", month_day.data))\n\n    if drop_feb29:\n        da = da.where(da[\"month_day\"] != \"02-29\", drop=True)\n\n    climatology = da.groupby(\"month_day\").mean(\"time\")\n    anomalies = da.groupby(\"month_day\") - climatology\n    return anomalies, climatology\n\n\ndef remove_seasonal_cycle_harmonic(data, n_harmonics=4, year_period=365.25):\n    \"\"\"Remove the seasonal cycle via harmonic least squares.\n\n    Works on 3D arrays (time, lat, lon). Set ``year_period=12`` for monthly data.\n    \"\"\"\n    n_time, n_lat, n_lon = data.shape\n    data_2d = data.reshape(n_time, -1)\n\n    t = np.arange(n_time)\n    X = np.ones((n_time, 2 * n_harmonics + 1))\n    for i in range(1, n_harmonics + 1):\n        X[:, 2 * i - 1] = np.sin(i * 2 * np.pi * t / year_period)\n        X[:, 2 * i] = np.cos(i * 2 * np.pi * t / year_period)\n\n    coeffs = np.linalg.lstsq(X, data_2d, rcond=None)[0]\n    return (data_2d - X @ coeffs).reshape(n_time, n_lat, n_lon)\n\n\ndef remove_seasonal_cycle_monthly_climatology(da):\n    \"\"\"Remove the seasonal cycle using monthly climatology (Jan–Dec means).\"\"\"\n    climatology = da.groupby(\"time.month\").mean(\"time\")\n    anomalies = da.groupby(\"time.month\") - climatology\n    return anomalies, climatology","key":"Y6vcHHSNX6"},{"type":"outputs","id":"2C-V23Dq5DibPFjx7JGJc","children":[],"key":"TDSdNl4pLk"}],"key":"FMIrCKP30v"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"daily_anom, _ = remove_seasonal_cycle_daily_climatology(uwind_850_da)\ndaily_anom.attrs[\"long_name\"] = \"850 hPa zonal wind anomalies (daily climatology)\"\n\nharmonic_anom = uwind_850_da.copy(\n    data=remove_seasonal_cycle_harmonic(uwind_850_da.values)\n)\nharmonic_anom.attrs[\"long_name\"] = \"850 hPa zonal wind anomalies (harmonic regression)\"\n\ndaily_anom, harmonic_anom = xr.align(daily_anom, harmonic_anom, join=\"inner\")","key":"ssRBKkE83h"},{"type":"outputs","id":"R9JUzddqcc2ORfSP1OjnF","children":[],"key":"smu4IHRAXf"}],"key":"cbqNIRSdyV"},{"type":"block","kind":"notebook-content","children":[{"type":"admonition","kind":"note","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Note","key":"vKsUQeKVSY"}],"key":"zAyHeR3kb5"},{"type":"paragraph","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"children":[{"type":"text","value":"Harmonic regression with ","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"MnZZ1a9FhQ"},{"type":"inlineMath","value":"N = 4","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>N</mi><mo>=</mo><mn>4</mn></mrow><annotation encoding=\"application/x-tex\">N = 4</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:0.6833em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.10903em;\">N</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span><span class=\"mrel\">=</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span></span><span class=\"base\"><span class=\"strut\" style=\"height:0.6444em;\"></span><span class=\"mord\">4</span></span></span></span>","key":"ohQxgPL5ga"},{"type":"text","value":" pairs of sin/cos terms produces a smooth seasonal cycle and is less noisy than a raw daily climatology, especially for short records. We align the two anomaly fields because daily climatology may drop February 29.","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"m71orCkmts"}],"key":"z5SrNt2pmH"}],"key":"DdzFFJFXws"}],"key":"I0jDWndfzf"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Compare daily anomalies","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Uelyl4PCxr"}],"identifier":"compare-daily-anomalies","label":"Compare daily anomalies","html_id":"compare-daily-anomalies","implicit":true,"key":"O6hXyYYuJ7"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"We inspect both methods at one tropical grid point (0°N, 180°E), over the area-weighted tropical mean (30°S–30°N), and in the time-mean map to confirm that anomalies are near zero on average.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"iKrfDpqvdY"}],"key":"tSrsPevbYR"}],"key":"sGJObtxLWO"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"lat_select = 0.0\nlon_select = 180.0\ntime_idx = 10\n\ndaily_point = daily_anom.sel(lat=lat_select, lon=lon_select, method=\"nearest\")\nharmonic_point = harmonic_anom.sel(\n    lat=lat_select, lon=lon_select, method=\"nearest\")\ndifference = daily_anom - harmonic_anom\ndifference_point = difference.sel(\n    lat=lat_select, lon=lon_select, method=\"nearest\")\n\nfig, axes = plt.subplots(1, 2, figsize=(12, 4))\ndaily_anom.isel(time=time_idx).plot(ax=axes[0])\naxes[0].set_title(\n    f\"Anomaly from daily climatology ({pd.to_datetime(daily_anom.time[time_idx].values):%Y-%m-%d})\")\nharmonic_anom.isel(time=time_idx).plot(ax=axes[1])\naxes[1].set_title(\n    f\"Anomaly from harmonic regression ({pd.to_datetime(harmonic_anom.time[time_idx].values):%Y-%m-%d})\")\nplt.tight_layout()\nplt.show()","key":"WtC8Fl12E9"},{"type":"outputs","id":"K8Xd1Lw30vdKCgH3B7NP0","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1200x400 with 4 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"6642a27ded7750ea8dcc1ced1b908b62","path":"/spectral-analysis-cookbook/build/6642a27ded7750ea8dcc1ced1b908b62.png"}}},"key":"RvFmbQwOU6"}],"key":"GXgmaFXHPH"}],"key":"AQxznfEI70"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fig, axes = plt.subplots(2, 1, figsize=(12, 6), sharex=True)\n\ndaily_point.plot(ax=axes[0], label=\"Daily climatology\", alpha=0.8)\nharmonic_point.plot(ax=axes[0], label=\"Harmonic regression\", alpha=0.8)\naxes[0].axhline(0, color=\"k\", linewidth=0.8)\naxes[0].set_title(\n    f\"850 hPa zonal-wind anomalies at lat={lat_select}, lon={lon_select}\")\naxes[0].set_ylabel(\"u-wind anomaly (m/s)\")\naxes[0].legend()\naxes[0].set_xlim(pd.Timestamp(\"1995-01-01\"), pd.Timestamp(\"1999-01-01\"))\n\ndifference_point.plot(ax=axes[1], color=\"green\")\naxes[1].set_title(\n    f\"Difference between daily and harmonic anomalies at lat={lat_select}, lon={lon_select}\")\naxes[1].axhline(0, color=\"k\", linewidth=0.8)\naxes[1].set_ylabel(\"Difference (m/s)\")\naxes[1].set_xlabel(\"Year\")\naxes[1].set_xlim(pd.Timestamp(\"1995-01-01\"), pd.Timestamp(\"1999-01-01\"))\nplt.tight_layout()\nplt.show()","key":"XKXG7rz673"},{"type":"outputs","id":"sfZuaMni8f1YADMDGrZu6","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1200x600 with 2 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"33a98dde56e7450a8e7a531e7243bc7f","path":"/spectral-analysis-cookbook/build/33a98dde56e7450a8e7a531e7243bc7f.png"}}},"key":"l5S6EdWXSP"}],"key":"WtGdbTNmSP"}],"key":"j7KYTYfUfs"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"weights = np.cos(np.deg2rad(daily_anom[\"lat\"]))\ndaily_tropical_mean = daily_anom.weighted(weights).mean((\"lat\", \"lon\"))\nharmonic_tropical_mean = harmonic_anom.weighted(weights).mean((\"lat\", \"lon\"))\n\nfig, axes = plt.subplots(1, 2, figsize=(14, 4))\n\ndaily_tropical_mean.plot(\n    ax=axes[0], label=\"Anomaly from daily climatology\", alpha=0.8)\nharmonic_tropical_mean.plot(\n    ax=axes[0], label=\"Anomaly from harmonic regression\", alpha=0.8)\naxes[0].axhline(0, color=\"k\", linewidth=0.8)\naxes[0].set_title(\"Tropical-mean anomalies\")\naxes[0].set_ylabel(\"u-wind anomaly (m/s)\")\naxes[0].legend()\n\ndaily_anom.mean(\"time\").plot(ax=axes[1], cmap=\"RdBu_r\", add_colorbar=True)\naxes[1].set_title(\"Time mean of daily-climatology anomalies (m/s)\")\nplt.tight_layout()\nplt.show()","key":"EPCyhRHnBf"},{"type":"outputs","id":"eI-2M7uRM8TLGlCTw7qQj","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1400x400 with 3 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"06a88da25c67f30c49f0ec66b714ff7a","path":"/spectral-analysis-cookbook/build/06a88da25c67f30c49f0ec66b714ff7a.png"}}},"key":"OBmAouC23x"}],"key":"rBfgUpRZDp"}],"key":"F4g6cyE4If"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"The time-mean anomaly map should be close to zero everywhere; values close to zero confirm that the seasonal cycle has been removed.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"GHE19FoozD"}],"key":"noO9hoNF7P"}],"key":"AUnPLRAr5O"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Fourier analysis of monthly anomalies","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"C9NFvG84SN"}],"identifier":"fourier-analysis-of-monthly-anomalies","label":"Fourier analysis of monthly anomalies","html_id":"fourier-analysis-of-monthly-anomalies","implicit":true,"key":"ccID78q8Ni"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"For spectral analysis we resample to ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"IswpLj2a7v"},{"type":"strong","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"monthly means","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"sTkAMk0PKU"}],"key":"QGbPK2o60S"},{"type":"text","value":", which suppresses day-to-day noise and makes the annual harmonics easier to interpret. At the selected grid point we remove the seasonal cycle again (monthly climatology vs. harmonic regression with ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"w3N7dyn9b1"},{"type":"inlineCode","value":"year_period=12","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"IHUCZlAO4Q"},{"type":"text","value":"), then apply the FFT to see which periods explain the most variance.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"Be2Wj9QYEU"}],"key":"NOHiJKorfq"}],"key":"IBq1oQNhW4"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"uwind_850_monthly = uwind_850_da.resample(time=\"MS\").mean()\nuwind_850_series = uwind_850_monthly.sel(\n    lat=lat_select, lon=lon_select, method=\"nearest\"\n)\n\nmonthly_clim_anom, _ = remove_seasonal_cycle_monthly_climatology(uwind_850_monthly)\nmonthly_harm_anom = xr.DataArray(\n    remove_seasonal_cycle_harmonic(\n        uwind_850_monthly.values, n_harmonics=4, year_period=12\n    ),\n    coords=uwind_850_monthly.coords,\n    dims=uwind_850_monthly.dims,\n)\n\nmonthly_clim_point = monthly_clim_anom.sel(\n    lat=lat_select, lon=lon_select, method=\"nearest\"\n)\nmonthly_harm_point = monthly_harm_anom.sel(\n    lat=lat_select, lon=lon_select, method=\"nearest\"\n)\nmonthly_clim_at_point = uwind_850_series.groupby(\"time.month\").mean(\"time\")\n\nfig, axes = plt.subplots(1, 2, figsize=(12, 4))\nuwind_850_series.plot(ax=axes[0])\naxes[0].set_title(f\"Monthly mean $u_{{850}}$ at lat={lat_select}, lon={lon_select}\")\nmonthly_clim_at_point.plot(ax=axes[1], marker=\"o\")\naxes[1].set_title(\"Monthly climatology at selected point\")\naxes[1].set_xticks(np.arange(1, 13))\nplt.tight_layout()\nplt.show()","key":"DujiN7X7Ba"},{"type":"outputs","id":"4FOEilz5gMVriXE0h7tGF","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1200x400 with 2 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"9629b8f3b247b9d45d7f789276fce25a","path":"/spectral-analysis-cookbook/build/9629b8f3b247b9d45d7f789276fce25a.png"}}},"key":"jvpVuzQkr0"}],"key":"a1zj5CRtHC"}],"key":"WN0fVLalyO"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def fft_percent_variance(series, sampling_interval=1):\n    \"\"\"Return positive periods (months) and percent variance explained.\"\"\"\n    centered = series - np.mean(series)\n    n = len(centered)\n    freqs = np.fft.fftfreq(n, d=sampling_interval)\n    coeffs = np.fft.fft(centered)\n    power = np.abs(coeffs) ** 2\n    pct = (power / np.sum(power)) * 100.0\n\n    periods = 1 / freqs\n    mask = np.isfinite(periods) & (periods > 0) & (pct > 0)\n    sort_idx = np.argsort(periods[mask])\n    return periods[mask][sort_idx], pct[mask][sort_idx]\n\n\nreference_periods = [12, 6, 4, 3]  # annual, semi-annual, and higher harmonics\n\nclim_periods, clim_pct = fft_percent_variance(monthly_clim_point.values)\nharm_periods, harm_pct = fft_percent_variance(monthly_harm_point.values)\n\nfig, ax = plt.subplots(figsize=(8, 4))\nax.semilogx(clim_periods, clim_pct, label=\"Monthly climatology anomalies\")\nax.semilogx(harm_periods, harm_pct, label=\"Harmonic regression anomalies\", alpha=0.8)\nfor period in reference_periods:\n    ax.axvline(period, color=\"gray\", linestyle=\"--\", linewidth=0.8, zorder=0)\nax.set_xlabel(\"Period (months)\")\nax.set_ylabel(\"Percent variance explained (%)\")\nax.set_title(f\"Fourier spectrum at lat={lat_select}, lon={lon_select}\")\nax.legend()\nax.grid(True, which=\"both\", alpha=0.3)\nplt.show()","key":"MnXyI4wAmL"},{"type":"outputs","id":"sBj94Yc9YpoLuCu5If6U5","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stderr","text":"/tmp/ipykernel_4384/1603101417.py:10: RuntimeWarning: divide by zero encountered in divide\n  periods = 1 / freqs\n"},"key":"LmdNz0TIIs"},{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 800x400 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"60a17bb11d5628c8d745b6de2873693c","path":"/spectra