{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"QQRx2I2vGw"}],"identifier":"generate-data","label":"Generate data","html_id":"generate-data","implicit":true,"key":"hPIBvPjS0K"}],"key":"nH0gZmY1Mc"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"sns.set_theme(style=\"whitegrid\", context=\"notebook\", font_scale=1.2)\nrng = np.random.default_rng(7)\n\ncenter = np.array([2.0, 1.0])\nscales = np.array([2.0, 0.6])\nangle = np.pi / 4\n\nrotation = np.array(\n    [[np.cos(angle), -np.sin(angle)],\n     [np.sin(angle), np.cos(angle)]]\n)\n\nn_samples = 10_000\ncloud = rotation @ np.diag(scales) @ rng.standard_normal((2, n_samples)) + center[:, None]\n\n\nplt.figure(figsize=(5, 5))\nplt.plot(cloud[0], cloud[1], \"o\", markersize=2, alpha=0.5, color='k')\nplt.plot(center[0], center[1], \"o\", color=\"red\", markersize=3, label=\"Center\")\nplt.legend()\nplt.axis(\"equal\")\nplt.title(\"2D Gaussian Cloud\");","key":"Is56B1NwW5"},{"type":"outputs","id":"oGXgVsLaKXKQFtv0ZyD_4","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 500x500 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"8dee5d8921491aaf77ca5dcbd8edaeb1","path":"/spectral-analysis-cookbook/build/8dee5d8921491aaf77ca5dcbd8edaeb1.png"}}},"key":"WGYF1saKEu"}],"key":"N1YbDK4Wo3"}],"key":"WKGfAcqYLi"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Analysis","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"g2oCfyJb98"}],"identifier":"analysis","label":"Analysis","html_id":"analysis","implicit":true,"key":"vWNA3m8JBN"}],"key":"c8uuLllMdI"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Remove mean:","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"pwajJic1iI"}],"key":"kHjLcDwv7o"}],"key":"Bxc7dbaKQA"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"","key":"AEwTEuaExG"},{"type":"outputs","id":"bMaTz_kTUg7KintLjXNK1","children":[],"key":"hi4eMnBLzM"}],"key":"yICKGbYjJP"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"mean = cloud.mean(axis=1, keepdims=True)\ndetrended_cloud = cloud - mean","key":"grg2EvuhCt"},{"type":"outputs","id":"EJl_aJOQ5aOgZjig7oczl","children":[],"key":"nQuaYXDgMD"}],"key":"Ozz7kORKJB"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Construct covariance matrices","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"qiHgXAAUwd"}],"key":"cL6n3tdx7t"}],"key":"LUR2daQh3X"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"cov_matrix_1 = (detrended_cloud @ detrended_cloud.T) / n_samples\ncov_matrix_2 = (detrended_cloud.T @ detrended_cloud) / n_samples\n\nprint(\"Covariance matrix 1 shape:\", cov_matrix_1.shape)\nprint(\"Covariance matrix 2 shape:\", cov_matrix_2.shape)","key":"yWS7l2FOWf"},{"type":"outputs","id":"TS4A96t0EIzo68U9uJIMh","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Covariance matrix 1 shape: (2, 2)\nCovariance matrix 2 shape: (10000, 10000)\n"},"key":"yicanETdoE"}],"key":"N1J3rA3aXh"}],"key":"mKY1VaoPWa"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Since matrix 1 is much smaller, 