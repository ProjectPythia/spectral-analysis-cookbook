"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Before carrying out the analysis, let’s take a look at the data on the first day:","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"SN4OUYrpUI"}],"key":"vdo85oQRuw"}],"key":"vDuXHrUpyi"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"projPC = ccrs.PlateCarree()\nfig = plt.figure(figsize=(10, 5), layout='constrained')\nax = plt.subplot(111, projection=projPC)\nuwind_ncep_ncar.uwnd.isel(level=0, time=0).plot(transform=projPC, cbar_kwargs={'orientation': 'horizontal'})\nax.scatter(90, 0, marker='x', color='k', s=50, transform=projPC, zorder=3)\nax.coastlines()\nax.gridlines(draw_labels=True, alpha=0.7)","key":"Mn3xlAXFze"},{"type":"outputs","id":"QT7HbqmDXbB98WdLAfbX8","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":4,"metadata":{},"data":{"text/plain":{"content":"<cartopy.mpl.gridliner.Gridliner at 0x7f80e4e2f620>","content_type":"text/plain"}}},"key":"el4QrC1kTd"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stderr","text":"/home/runner/micromamba/envs/cookbook-dev/lib/python3.14/site-packages/cartopy/io/__init__.py:242: DownloadWarning: Downloading: https://naturalearth.s3.amazonaws.com/110m_physical/ne_110m_coastline.zip\n  warnings.warn(f'Downloading: {url}', DownloadWarning)\n"},"key":"ky5TzstX4I"},{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1000x500 with 2 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"4956a949c9c75d0ac8b5f4c0b8794acc","path":"/spectral-analysis-cookbook/_preview/19/build/4956a949c9c75d0ac8b5f4c0b8794acc.png"}}},"key":"XLBsN5tn4q"}],"key":"GCCMwgt0DO"}],"key":"pnLNfkYox5"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"We will perform the FFT at one location first. Let’s select a location over the eastern Indian Ocean, indicated by the X in the above plot.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"pVNZ0vd8XL"}],"key":"JRq82TwskK"}],"key":"ZdImcfd14w"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"uwind_ei = uwind_ncep_ncar.uwnd.isel(level=0).sel(lat=0, lon=90)\nuwind_ei.plot()","key":"kDuE0SwsRx"},{"type":"outputs","id":"dNZ1uFST-57G1JPmp5xtm","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"b8fede013ad402077f42d7b40d4f9511","path":"/spectral-analysis-cookbook/_preview/19/build/b8fede013ad402077f42d7b40d4f9511.png"}}},"key":"U4KIxDM9sF"}],"key":"F0HZzJK6wX"}],"key":"g5vdJWJZyC"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"We need to center the data by removing its time mean.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"blw73XpvN8"}],"key":"UzOa3OJSTb"}],"key":"XZ5eGwS7dR"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"centered_series = uwind_ei - uwind_ei.mean(dim='time')","key":"m2tipGHoCg"},{"type":"outputs","id":"gUYnKPEQzC416izHPW_tq","children":[],"key":"V0uo2J5uOK"}],"key":"vnhpoB0cNZ"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"centered_series.plot()","key":"uSZXhsqngB"},{"type":"outputs","id":"4Tw3zY32jrSFXwPSSbd5g","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metada