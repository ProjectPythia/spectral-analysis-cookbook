ok-code","children":[{"type":"code","lang":"python","executable":true,"value":"sns.set_theme(style=\"whitegrid\", context=\"notebook\", font_scale=1.2)\nrng = np.random.default_rng(7)\n\ncenter = np.array([2.0, 1.0])\nscales = np.array([2.0, 0.6])\nangle = np.pi / 4\n\nrotation = np.array(\n    [[np.cos(angle), -np.sin(angle)],\n     [np.sin(angle), np.cos(angle)]]\n)\n\nn_samples = 10_000\ncloud = rotation @ np.diag(scales) @ rng.standard_normal((2, n_samples)) + center[:, None]\n\n\nplt.figure(figsize=(5, 5))\nplt.plot(cloud[0], cloud[1], \"o\", markersize=2, alpha=0.5, color='k')\nplt.plot(center[0], center[1], \"o\", color=\"red\", markersize=3, label=\"Center\")\nplt.legend()\nplt.axis(\"equal\")\nplt.title(\"2D Gaussian Cloud\");","key":"kzNpz1nSJ8"},{"type":"outputs","id":"eVhSezylH7rTuf-HE_Y15","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 500x500 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"1b311c98a11c382669df124bb9747d62","path":"/spectral-analysis-cookbook/_preview/20/build/1b311c98a11c382669df124bb9747d62.png"}}},"key":"Asca5SXGUe"}],"key":"zpJng3WQ1K"}],"key":"UtZ0EqZ3id"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Analysis","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"tzCYmSZlt3"}],"identifier":"analysis","label":"Analysis","html_id":"analysis","implicit":true,"key":"PFWTIDksbU"}],"key":"xWVF91la9c"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Remove mean:","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"rXtfo3zig6"}],"key":"Dg2YTTF1Pb"}],"key":"vSWKTacV6P"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"","key":"VhVLA8O08w"},{"type":"outputs","id":"fl8eUEvpXC2kX-B1F6o2g","children":[],"key":"XFrq6sUZav"}],"key":"OuGiZ7Kc1w"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"mean = cloud.mean(axis=1, keepdims=True)\ndetrended_cloud = cloud - mean","key":"BWNQonnXgD"},{"type":"outputs","id":"U2kNiACjxAgn5cf_tuxpq","children":[],"key":"VDNqI6qfFH"}],"key":"LeQ5hZrP9y"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Construct covariance matrices","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"XKgREdLibl"}],"key":"s6f2Uxi4Zh"}],"key":"ZqBHxZ0rc4"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"cov_matrix_1 = (detrended_cloud @ detrended_cloud.T) / n_samples\ncov_matrix_2 = (detrended_cloud.T @ detrended_cloud) / n_samples\n\nprint(\"Covariance matrix 1 shape:\", cov_matrix_1.shape)\nprint(\"Covariance matrix 2 shape:\", cov_matrix_2.shape)","key":"TFy9Fn8a4V"},{"type":"outputs","id":"_Mh9MRM0MmDfBm7D0JSIf","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Covariance matrix 1 shape: (2, 2)\nCovariance matrix 2 shape: (10000, 10000)\n"},"key":"t2ufElQ5MB"}],"key":"DDT7Z4svUd"}],"key":"L9ovsw6WPv"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Since matrix 1 is much smaller, we will find its eigenvalues.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"JCyEuloT4N"}],"key":"gRU0lZTKwI"}],"key":"CBntBgi2ys"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"eigen_val, eigen_vect = np.linalg.eig(cov_matrix_1)","key":"i2ceRLlVeb"},{"type":"outputs","id":"v74Qwj-GQJ8UBNUWOxafH","children":[],"key":"yvvcaqkkK9"}],"key":"HNz0REnl77"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"eigen_val","key":"KmXedgeYPQ"},{"type":"outputs","id":"2-KfrTsxF3i5Ae5-jvgu2","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":6,"metadata":{},"data":{"text/plain":{"content":"array([3.95439111, 0.35316582])","content_type":"text/plain"}}},"key":"HsfNVS05Xd"}],"key":"YecOhprfUf"}],"key":"AJKSDDzf87"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Visualize results","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"GXhOTldAcc"}],"identifier":"visualize-results","label":"Visualize results","html_id":"visualize-results","implicit":true,"key":"uXNDi7PaJ6"}],"key":"LTYd5VRZcV"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"eigen_vect","key":"CMyr2BeAHO"},{"type":"outputs","id":"4ojUEyC2f5OovqnCtWF3d","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":7,"metadata":{},"data":{"text/plain":{"content":"array([[ 0.70990989, -0.70429252],\n       [ 0.70429252,  0.70990989]])","content_type":"text/plain"}}},"key":"K40yo4sRtH"}],"key":"gaJ8De5DvJ"}],"key":"bD17wHuvNB"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fig, (ax_left, ax_right) = plt.subplots(1, 2, figsize=(10, 4),\n                                        sharex=True, sharey=True)\n\nax_left.scatter(cloud[0], cloud[1], s=2, c=\"black\", alpha=0.35)\nax_left.set_title(\"Generated cloud\")\n\nax_right.scatter(cloud[0], cloud[1], s=2, c=\"black\", alpha=0.35)\nax_right.set_title(\"PCA axes\")\n\nfor direction, length in zip(eigen_vect.T, eigen_val):\n    endpoint = mean[:, 0] + direction * np.sqrt(length)\n    ax_right.arrow(\n        mean[0, 0],\n        mean[1, 0],\n        endpoint[0] - mean[0, 0],\n        endpoint[1] - mean[1, 0],\n        color=\"magenta\",\n        linewidth=1.5,\n        length_includes_head=True,\n        head_width=0.15,\n        head_length=0.2,\n        zorder=5\n    )\n\nfor ax in (ax_left, ax_right):\n    ax.plot(center[0], center[1], \"o\", color=\"red\", markersize=3, label=\"Center\")\n    ax.set_aspect(\"equal\")\n    ax.set_xlim(-6, 8)\n    ax.set_ylim(-6, 8)\n","key":"hEjmysBAZY"},{"type":"outputs","id":"um3-vMV4L0JA8oQZeCnYI","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1000x400 with 2 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"a3d1a3771ea9529eb0bb6c65168e2d93","path":"/spectral-analysis-cookbook/_preview/20/build/a3d1a3771ea9529eb0bb6c65168e2d93.png"}}},"key":"H9cWPA7JOb"}],"key":"VxrJmHtNA0"}],"key":"yDmFmcDPUi"},{"type":"block","kind":"notebook-content","children":[{"type":"thematicBreak","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"cC9PHHSO3B"}],"key":"WXJPsndazP"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Summary","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Md2XfDfRzK"}],"identifier":"summary","label":"Summary","html_id":"summary","implicit":true,"key":"SpYZicRgXL"},{"type":"paragraph","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"children":[{"type":"text","value":"TBD","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"ke