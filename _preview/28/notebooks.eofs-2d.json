n_samples = 10_000\ncloud = rotation @ np.diag(scales) @ rng.standard_normal((2, n_samples)) + center[:, None]\n\n\nplt.figure(figsize=(5, 5))\nplt.plot(cloud[0], cloud[1], \"o\", markersize=2, alpha=0.5, color='k')\nplt.plot(center[0], center[1], \"o\", color=\"red\", markersize=3, label=\"Center\")\nplt.legend()\nplt.axis(\"equal\")\nplt.title(\"2D Gaussian Cloud\");","key":"KzFOn28puj"},{"type":"outputs","id":"KugWs9jNOkp1d0IWiji9y","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 500x500 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"1b311c98a11c382669df124bb9747d62","path":"/spectral-analysis-cookbook/_preview/28/build/1b311c98a11c382669df124bb9747d62.png"}}},"key":"I1PaJ0zHXn"}],"key":"FEdCW6EP3X"}],"key":"gO4DujAtoE"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Analysis","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"jDVbUWeyQH"}],"identifier":"analysis","label":"Analysis","html_id":"analysis","implicit":true,"key":"g72rxOiqmC"}],"key":"XQ4t0QwoYS"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Remove mean:","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"BSUcSzbA7Q"}],"key":"uRI0XLKbem"}],"key":"r7QhVhf2QY"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"","key":"Sb4O1ygB82"},{"type":"outputs","id":"DsBU00jZfNyR-VGFZK0yb","children":[],"key":"T5AEMevEjv"}],"key":"EnXOH3yfnJ"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"mean = cloud.mean(axis=1, keepdims=True)\ndetrended_cloud = cloud - mean","key":"LJBvukaxV6"},{"type":"outputs","id":"lb08AIHVOhbspMqzmsNGi","children":[],"key":"uimyuAlMfH"}],"key":"uRhfC5K8iL"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Construct covariance matrices","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"qJystRW5bV"}],"key":"YUdyQ6e5dU"}],"key":"Ercr0LKHS3"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"cov_matrix_1 = (detrended_cloud @ detrended_cloud.T) / n_samples\ncov_matrix_2 = (detrended_cloud.T @ detrended_cloud) / n_samples\n\nprint(\"Covariance matrix 1 shape:\", cov_matrix_1.shape)\nprint(\"Covariance matrix 2 shape:\", cov_matrix_2.shape)","key":"SBtq8xB1HP"},{"type":"outputs","id":"aASR6AzWV3oa_yvf8Bfvf","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Covariance matrix 1 shape: (2, 2)\nCovariance matrix 2 shape: (10000, 10000)\n"},"key":"Z0sckgJCGJ"}],"key":"SJrMxXtuOa"}],"key":"bZicyZSaSO"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Since matrix 1 is much smaller, we will find its eigenvalues.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Hh8uIN4y8Y"}],"key":"Vfryhdr6Ui"}],"key":"IIpd6xtfML"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"eigen_val, eigen_vect = np.linalg.eig(cov_matrix_1)","key":"avQmfjG9S0"},{"type":"outputs","id":"WBUcVrt_yGyxFq1DA5jr9","children":[],"key":"qD18xNLqqr"}],"key":"dySZLvZ9oo"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"eigen_val","key":"OB8zYeokXS"},{"type":"outputs","id":"VH9yi-biyGt32ZFrxKWeI","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":6,"metadata":{},"data":{"text/plain":{"content":"array([3.95439111, 0.35316582])","content_type":"text/plain"}}},"key":"zt1e44gBhY"}],"key":"XSLDUUsb5Z"}],"key":"CyoorIDprd"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Visualize results","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"MdgR6TsbVd"}],"identifier":"visualize-results","label":"Visualize results","html_id":"visualize-results","implicit":true,"key":"i0DS6kMDxT"}],"key":"W0TbI7OttN"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"eigen_vect","key":"fxTtQZy2sx"},{"type":"outputs","id":"psNt6rsApIggLVuc_3nsg","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":7,"metadata":{},"data":{"text/plain":{"content":"array([[ 0.70990989, -0.70429252],\n       [ 0.70429252,  0.70990989]])","content_type":"text/plain"}}},"key":"QmyRlfqZyf"}],"key":"Z7uO9sXv6D"}],"key":"SDzJ2SVouc"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fig, (ax_left, ax_right) = plt.subplots(1, 2, figsize=(10, 4),\n                                        sharex=True, sharey=True)\n\nax_left.scatter(cloud[0], cloud[1], s=2, c=\"black\", alpha=0.35)\nax_left.set_title(\"Generated cloud\")\n\nax_right.scatter(cloud[0], cloud[1], s=2, c=\"black\", alpha=0.35)\nax_right.set_title(\"PCA axes\")\n\nfor direction, length in zip(eigen_vect.T, eigen_val):\n    endpoint = mean[:, 0] + direction * np.sqrt(length)\n    ax_right.arrow(\n        mean[0, 0],\n        mean[1, 0],\n        endpoint[0] - mean[0, 0],\n        endpoint[1] - mean[1, 0],\n        color=\"magenta\",\n        linewidth=1.5,\n        length_includes_head=True,\n        head_width=0.15,\n        head_length=0.2,\n        zorder=5\n    )\n\nfor ax in (ax_left, ax_right):\n    ax.plot(center[0], center[1], \"o\", color=\"red\", markersize=3, label=\"Center\")\n    ax.set_aspect(\"equal\")\n    ax.set_xlim(-6, 8)\n    ax.set_ylim(-6, 8)\n","key":"lqFBJNSe97"},{"type":"outputs","id":"EC-A8tXkoA5iuKmNwRDjf","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1000x400 with 2 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"a3d1a3771ea9529eb0bb6c65168e2d93","path":"/spectral-analysis-cookbook/_preview/28/build/a3d1a3771ea9529eb0bb6c65168e2d93.png"}}},"key":"dDXWgat1gT"}],"key":"e2pT4d9WDo"}],"key":"AGhyCjE0lk"},{"type":"block","kind":"notebook-content","children":[{"type":"thematicBreak","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"l3X8DYYbdU"}],"key":"yW5DJLiX6B"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Summary","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"hdPukittm3"}],"identifier":"summary","label":"Summary","html_id":"summary","implicit":true,"key":"Z5fSzfFjFY"},{"type":"paragraph","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"children":[{"type":"text","value":"TBD","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"RE9UXUTx6I"}],"key":"OLGJ5REFap"},{"type":"heading","depth":3,"position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"What’s next?","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"tNaun0qID6"}],"identifier":"whats-next","label":"What’s next?","html_id":"whats-next","implicit":true,"key":"