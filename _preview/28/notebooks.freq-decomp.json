utput","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"b8fede013ad402077f42d7b40d4f9511","path":"/spectral-analysis-cookbook/_preview/28/build/b8fede013ad402077f42d7b40d4f9511.png"}}},"key":"zPxRRtTVXS"}],"key":"yuXcAkZ4PI"}],"key":"qZTRdysB5R"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"We need to center the data by removing its time mean.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"IIqnuFweGS"}],"key":"bTSe12efEK"}],"key":"MVJ0utslNr"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"centered_series = uwind_ei - uwind_ei.mean(dim='time')","key":"Umv457an1q"},{"type":"outputs","id":"fozlDTSC863g1FT9Srwgq","children":[],"key":"jcRhge8cWf"}],"key":"X89IRTZCYh"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"centered_series.plot()","key":"rbxhqLxb8X"},{"type":"outputs","id":"WZs2eczFNmFV6a8YWQLi-","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"edefd7de69873a7b57996201c2f3933a","path":"/spectral-analysis-cookbook/_preview/28/build/edefd7de69873a7b57996201c2f3933a.png"}}},"key":"AOMI1UrzYu"}],"key":"gdjocvtJJ0"}],"key":"hNsNJC1xKJ"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"We now perform the FFT, also computing the explained variance in percent.","position":{"start":{"line":1,"col