","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"YdxdqpVVTw"}],"identifier":"generate-data","label":"Generate data","html_id":"generate-data","implicit":true,"key":"Yz4LEZjcUU"}],"key":"zrJPcSNXPO"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"sns.set_theme(style=\"whitegrid\", context=\"notebook\", font_scale=1.2)\nrng = np.random.default_rng(7)\n\ncenter = np.array([2.0, 1.0])\nscales = np.array([2.0, 0.6])\nangle = np.pi / 4\n\nrotation = np.array(\n    [[np.cos(angle), -np.sin(angle)],\n     [np.sin(angle), np.cos(angle)]]\n)\n\nn_samples = 10_000\ncloud = rotation @ np.diag(scales) @ rng.standard_normal((2, n_samples)) + center[:, None]\n\n\nplt.figure(figsize=(5, 5))\nplt.plot(cloud[0], cloud[1], \"o\", markersize=2, alpha=0.5, color='k')\nplt.plot(center[0], center[1], \"o\", color=\"red\", markersize=3, label=\"Center\")\nplt.legend()\nplt.axis(\"equal\")\nplt.title(\"2D Gaussian Cloud\");","key":"O6TF2h7BpP"},{"type":"outputs","id":"S4mGtA1J5HlfTpmAVlVCg","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 500x500 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"1b311c98a11c382669df124bb9747d62","path":"/spectral-analysis-cookbook/_preview/18/build/1b311c98a11c382669df124bb9747d62.png"}}},"key":"PAOVaLuAzq"}],"key":"xrrgsWsJfC"}],"key":"RW4hdwJC6r"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Analysis","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"nK5AO8227E"}],"identifier":"analysis","label":"Analysis","html_id":"analysis","implicit":true,"key":"FkCTwsqmLW"}],"key":"oIeMGwDIUW"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Remove mean:","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"OvsgI4CFbO"}],"key":"ZM8J362JC4"}],"key":"dK6jD23JeB"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"","key":"h5qHeG8SEH"},{"type":"outputs","id":"WOyIdPpR9nWNp44uCIncq","children":[],"key":"EzlqPrgpoa"}],"key":"hFrqT1dGM1"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"mean = cloud.mean(axis=1, keepdims=True)\ndetrended_cloud = cloud - mean","key":"CdIMFu8L2t"},{"type":"outputs","id":"V61oQM4lyu2doehdGVXl4","children":[],"key":"PWcF17VBT4"}],"key":"GzxsxCK4pf"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Construct covariance matrices","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Wv3Ag30GJy"}],"key":"FSJlTM3v1N"}],"key":"qZX3F5wu2h"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"cov_matrix_1 = (detrended_cloud @ detrended_cloud.T) / n_samples\ncov_matrix_2 = (detrended_cloud.T @ detrended_cloud) / n_samples\n\nprint(\"Covariance matrix 1 shape:\", cov_matrix_1.shape)\nprint(\"Covariance matrix 2 shape:\", cov_matrix_2.shape)","key":"AoUu4UriVO"},{"type":"outputs","id":"iQN7UiM2uOMDP7ZrJFcKF","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Covariance matrix 1 shape: (2, 2)\nCovariance matrix 2 shape: (10000, 10000)\n"},"key":"MeT6WVMnZN"}],"key":"TbOuZy0ZEK"}],"key":"ghkkAksrim"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Since matrix 1 is much smaller, we will find its eigenvalues.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"oEFv1C8J54"}],"key":"tpbofFF2rK"}],"key":"o5qR7pq3iq"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"eigen_val, eigen_vect = np.linalg.eig(cov_matrix_1)","key":"Mm3rXDThSk"},{"type":"outputs","id":"aIJQ0K7NaJkP-DYCshTlC","children":[],"key":"tnTmDMXG1S"}],"key":"MhCxqrAz7c"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"eigen_val","key":"Q69XIWQziZ"},{"type":"outputs","id":"4wYZQ5yvxK3VlUUwNotH7","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":6,"metadata":{},"data":{"text/plain":{"content":"array([3.95439111, 0.35316582])","content_type":"text/plain"}}},"key":"qRt3jVrtad"}],"key":"b146K67A7O"}],"key":"fykgKSK3kk"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Visualize results","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"c8ytwKtxBX"}],"identifier":"visualize-results","label":"Visualize results","html_id":"visualize-results","implicit":true,"key":"F2rmBdKnLp"}],"key":"gFiRc3rQAA"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"eigen_vect","key":"jKmdH6Z3JQ"},{"type":"outputs","id":"1n8uycRgezh3YHu7DIQd7","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":7,"metadata":{},"data":{"text/plain":{"content":"array([[ 0.70990989, -0.70429252],\n       [ 0.70429252,  0.70990989]])","content_type":"text/plain"}}},"key":"C8HHsyPWee"}],"key":"JdUbllRJqj"}],"key":"RajgTtcwWc"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fig, (ax_left, ax_right) = plt.subplots(1, 2, figsize=(10, 4),\n                                        sharex=True, sharey=True)\n\nax_left.scatter(cloud[0], cloud[1], s=2, c=\"black\", alpha=0.35)\nax_left.set_title(\"Generated cloud\")\n\nax_right.scatter(cloud[0], cloud[1], s=2, c=\"black\", alpha=0.35)\nax_right.set_title(\"PCA axes\")\n\nfor direction, length in zip(eigen_vect.T, eigen_val):\n    endpoint = mean[:, 0] + direction * np.sqrt(length)\n    ax_right.arrow(\n        mean[0, 0],\n        mean[1, 0],\n        endpoint[0] - mean[0, 0],\n        endpoint[1] - mean[1, 0],\n        color=\"magenta\",\n        linewidth=1.5,\n        length_includes_head=True,\n        head_width=0.15,\n        head_length=0.2,\n        zorder=5\n    )\n\nfor ax in (ax_left, ax_right):\n    ax.plot(center[0], center[1], \"o\", color=\"red\", markersize=3, label=\"Center\")\n    ax.set_aspect(\"equal\")\n    ax.set_xlim(-6, 8)\n    ax.set_ylim(-6, 8)\n","key":"CTlnDTg7Ec"},{"type":"outputs","id":"GCjI3HpVbbEkHQ_UL5t9_","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1000x400 with 2 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"a3d1a3771ea9529eb0bb6c65168e2d93","path":"/spectral-analysis-cookbook/_preview/18/build/a3d1a3771ea9529eb0bb6c65168e2d93.png"}}},"key":"pvG5qsWRvW"}],"key":"kyJNXNQn13"}],"key":"XUzuus76Zb"},{"type":"block","kind":"notebook-content","children":[{"type":"thematicBreak","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"SJP8I6fEUu"}],"key":"xDUtUSgO2M"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Summary","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"pb9eCQjZBa"}],"identifier":"summary","label":"Summary","h