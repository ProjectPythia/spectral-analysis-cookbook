,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"hhxSksWKwY"}],"identifier":"generate-data","label":"Generate data","html_id":"generate-data","implicit":true,"key":"f8GQ3m9XMG"}],"key":"ASFgmNKqF5"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"sns.set_theme(style=\"whitegrid\", context=\"notebook\", font_scale=1.2)\nrng = np.random.default_rng(7)\n\ncenter = np.array([2.0, 1.0])\nscales = np.array([2.0, 0.6])\nangle = np.pi / 4\n\nrotation = np.array(\n    [[np.cos(angle), -np.sin(angle)],\n     [np.sin(angle), np.cos(angle)]]\n)\n\nn_samples = 10_000\ncloud = rotation @ np.diag(scales) @ rng.standard_normal((2, n_samples)) + center[:, None]\n\n\nplt.figure(figsize=(5, 5))\nplt.plot(cloud[0], cloud[1], \"o\", markersize=2, alpha=0.5, color='k')\nplt.plot(center[0], center[1], \"o\", color=\"red\", markersize=3, label=\"Center\")\nplt.legend()\nplt.axis(\"equal\")\nplt.title(\"2D Gaussian Cloud\");","key":"nc6QXdyH5W"},{"type":"outputs","id":"spyKtd-eWjPn3eVPaeofg","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 500x500 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"8dee5d8921491aaf77ca5dcbd8edaeb1","path":"/spectral-analysis-cookbook/_preview/15/build/8dee5d8921491aaf77ca5dcbd8edaeb1.png"}}},"key":"RDdW5ZAiUG"}],"key":"oOxb4iHDXQ"}],"key":"xdOcUjkcJB"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Analysis","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"OnX0beFooG"}],"identifier":"analysis","label":"Analysis","html_id":"analysis","implicit":true,"key":"lgZ3BbD38P"}],"key":"VhBA7eCvqX"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Remove mean:","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"JDeOfFhvOR"}],"key":"wiYTWG5CYt"}],"key":"TBZqltCytr"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"","key":"sWRcXVN5kx"},{"type":"outputs","id":"GM0tRTysl4CB8E-d0qWmd","children":[],"key":"XJkiiQQGbP"}],"key":"AQ61CohLP9"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"mean = cloud.mean(axis=1, keepdims=True)\ndetrended_cloud = cloud - mean","key":"Ue2k6R5S13"},{"type":"outputs","id":"sIR1hQ2IOK5SOBfpIgvI1","children":[],"key":"cOBGpaIcv9"}],"key":"Q5fAysiClL"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Construct covariance matrices","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"TNtOu8gTU5"}],"key":"YPFm9RIjdr"}],"key":"fil8h7G1sD"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"cov_matrix_1 = (detrended_cloud @ detrended_cloud.T) / n_samples\ncov_matrix_2 = (detrended_cloud.T @ detrended_cloud) / n_samples\n\nprint(\"Covariance matrix 1 shape:\", cov_matrix_1.shape)\nprint(\"Covariance matrix 2 shape:\", cov_matrix_2.shape)","key":"ESYNGZ5O5u"},{"type":"outputs","id":"d0HD4yXTMqF92uiKDpYaf","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Covariance matrix 1 shape: (2, 2)\nCovariance matrix 2 shape: (10000, 10000)\n"},"key":"I1VIVFPoNh"}],"key":"CTOauKRcme"}],"key":"EGOctYHTCs"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Since matrix 1 is much smaller, we will find its eigenvalues.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"BLOxQqE0ue"}],"key":"ZWjtKgIUsg"}],"key":"bThGw4jFlj"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"eigen_val, eigen_vect = np.linalg.eig(cov_matrix_1)","key":"Kk9RBepkog"},{"type":"outputs","id":"XaEcqHig3Ffom40D53ZYa","children":[],"key":"RZNZD05Vbh"}],"key":"sb2uJCDoXb"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"eigen_val","key":"EUqcKJjQZC"},{"type":"outputs","id":"bg5BR_HMDCWxOFgzFuzga","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":6,"metadata":{},"data":{"text/plain":{"content":"array([3.95439111, 0.35316582])","content_type":"text/plain"}}},"key":"Z9XIq3qnVb"}],"key":"bTZ8rt1wb8"}],"key":"HOUdwpQVVC"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Visualize results","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"eOLKkE2MhS"}],"identifier":"visualize-results","label":"Visualize results","html_id":"visualize-results","implicit":true,"key":"Fb9UDqkIlA"}],"key":"qgr1Lnv8yA"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"eigen_vect","key":"yLdid7BasR"},{"type":"outputs","id":"uiJaTkz1D0gZa8hAiMYN6","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":7,"metadata":{},"data":{"text/plain":{"content":"array([[ 0.70990989, -0.70429252],\n       [ 0.70429252,  0.70990989]])","content_type":"text/plain"}}},"key":"bBuQkJiqGO"}],"key":"znhcojYbuL"}],"key":"nP34r8HAr4"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fig, (ax_left, ax_right) = plt.subplots(1, 2, figsize=(10, 4),\n                                        sharex=True, sharey=True)\n\nax_left.scatter(cloud[0], cloud[1], s=2, c=\"black\", alpha=0.35)\nax_left.set_title(\"Generated cloud\")\n\nax_right.scatter(cloud[0], cloud[1], s=2, c=\"black\", alpha=0.35)\nax_right.set_title(\"PCA axes\")\n\nfor direction, length in zip(eigen_vect.T, eigen_val):\n    endpoint = mean[:, 0] + direction * np.sqrt(length)\n    ax_right.arrow(\n        mean[0, 0],\n        mean[1, 0],\n        endpoint[0] - mean[0, 0],\n        endpoint[1] - mean[1, 0],\n        color=\"magenta\",\n        linewidth=1.5,\n        length_includes_head=True,\n        head_width=0.15,\n        head_length=0.2,\n        zorder=5\n    )\n\nfor ax in (ax_left, ax_right):\n    ax.plot(center[0], center[1], \"o\", color=\"red\", markersize=3, label=\"Center\")\n    ax.set_aspect(\"equal\")\n    ax.set_xlim(-6, 8)\n    ax.set_ylim(-6, 8)\n","key":"IKuOjuOCcJ"},{"type":"outputs","id":"DcQ_616Qb-EdIK_zYzJz6","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1000x400 with 2 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"e4d79707b9870f56048ca4aa43414dcd","path":"/spectral-analysis-cookbook/_preview/15/build/e4d79707b9870f56048ca4aa43414dcd.png"}}},"key":"yatpZuEJnH"}],"key":"cQGpIOEsUb"}],"key":"nXn8c9kT0b"},{"type":"block","kind":"notebook-content","children":[{"type":"thematicBreak","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"fiTpfPdLLd"}],"key":"SVEbwpQQX8"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Summary","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"A84oRCp0eK"}],"identifier":"summary","label":"Summary","ht