ren":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"b8fede013ad402077f42d7b40d4f9511","path":"/spectral-analysis-cookbook/_preview/25/build/b8fede013ad402077f42d7b40d4f9511.png"}}},"key":"kmOqq0oHRT"}],"key":"TbV54qMO0s"}],"key":"ECDjdRefXy"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"We need to center the data by removing its time mean.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"WltUWWnMHQ"}],"key":"p9zxrNSRnz"}],"key":"ZnG3cB2C2j"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"centered_series = uwind_ei - uwind_ei.mean(dim='time')","key":"gWYb9CkOcs"},{"type":"outputs","id":"JhSwkHoq4gozqZMkqXY8Z","children":[],"key":"kwV8soomZF"}],"key":"zLev6pmg4X"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"centered_series.plot()","key":"UgfkbIn6lQ"},{"type":"outputs","id":"a71ovE6TaSOKpj14FqHTK","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"edefd7de69873a7b57996201c2f3933a","path":"/spectral-analysis-cookbook/_preview/25/build/edefd7de69873a7b57996201c2f3933a.png"}}},"key":"lc2AG78Zq3"}],"key":"Hzd9H4eKqY"}],"key":"lYkD1T5fTD"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"We now perform the FFT, also computing the explained variance in percent.","position":{"start":{"line":1,"column":1},"end"