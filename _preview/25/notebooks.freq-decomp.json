e,"position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Apply FFT to compute frequency spectrum and convert to period domain","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"bl5I3Hw3Jt"}],"key":"BW0XJiPSOQ"}],"key":"WAzeC2hnVP"},{"type":"listItem","spread":true,"position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Calculate normalized power spectrum scaled by variance","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"BYgDK4gisC"}],"key":"z6ADvCtz1j"}],"key":"EKCcWZHEff"},{"type":"listItem","spread":true,"position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Apply frequency masks to isolate different bands","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"key":"BIJaSIzIEi"}],"key":"Ac8zV8JqJq"}],"key":"QW4Gw9vSXM"},{"type":"listItem","spread":true,"position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Compute variance and explained variance (%) for each band","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"iHJKrXdKPj"}],"key":"ZdQN1uUZns"}],"key":"quh92FiuUf"}],"key":"v35dk3jdfv"}],"key":"LfvzMYf1Cr"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"As an example from the single location, we can compute the explained variance associated with the annual cycle, giving us about 12%:","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"ATN9c4XUL6"}],"key":"hGISS4ttBg"}],"key":"XFBmZ4WRrH"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# mask to extract different bands\nac_period = (364, 366)  # days\nmask_AC = np.where((np.abs(periods) >= ac_period[0]) &\n                    (periods <= ac_period[1]))\n\n# Compute explained variances for each band\nexp_var_AC = np.nansum(exp_var[mask_AC])\nexp_var_AC","key":"zGJHsZwgC1"},{"type":"outputs","id":"5ccGcz_ZWzY8btnQzv872","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":10,"metadata":{},"data":{"text/plain":{"content":"np.float32(0.1229185)","content_type":"text/plain"}}},"key":"G9bMiIu7af"}],"key":"gM67B9x3RG"}],"key":"l3m7bv4Qqa"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"uwind_ncep_ncar.uwnd.shape","key":"HjQce5aHta"},{"type":"outputs","id":"9pp1r6R7eniH9MsTwPEIj","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":11,"metadata":{},"data":{"text/plain":{"content":"(17167, 2, 25, 144)","content_type":"text/plain"}}},"key":"arT629yWZI"}],"key":"Akg2CZMJUM"}],"key":"WNlcHCF6tw"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Set up variables and empty arrays:","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"rRHM1an8Gd"}],"key":"of4tFgfvaJ"}],"key":"VgeyXsphM1"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"data_array = uwind_ncep_ncar.isel(level=0).uwnd.values\n\n# Get the shape of the data array\ndtime, dlat, dlon = data_array.shape\n\n# Reshape data to 2D array: (time, space) for easier processing\ndata_reshaped = data_array.reshape(dtime, dlat * dlon)\n\n# Variance for different frequency bands\nvar_AC = np.zeros(dlat * dlon) * np.nan  # Annual Cycle\nvar_IS = np.zeros(dlat * dlon) * np.nan  # Intra-Seasonal Cycle\nvar_IA = np.zeros(dlat * dlon) * np.nan  # Inter-Annual Cycle\nvar_BG = np.zeros(dlat * dlon) * np.nan  # Background (longer than 100 days)\nvar_SS = np.zeros(dlat * dlon) * np.nan  # Subseasonal (shorter than 80 days)\n\n\n# Explained variance for different frequency bands\nexp_var_AC = np.zeros(dlat * dlon) * np.nan  # Annual Cycle\nexp_var_IS = np.zeros(dlat * dlon) * np.nan  # Intra-Seasonal\nexp_var_IA = np.zeros(dlat * dlon) * np.nan  # Inter-Annual Cycle\n\n# Background (longer than 100 days)\nexp_var_BG = np.zeros(dlat * dlon) * np.nan\n# Subseasonal (shorter than 80 days)\nexp_var_SS = np.zeros(dlat * dlon) * np.nan\n\n# Annual, Intra-Seasonal, Inter-annual periods in days\nac_period = (364, 366)  # days\nis_period = (20, 90)  # days\nia_period = (2*365.25, 7*365.25)  # days\n\n# Background and Subseasonal cutoff periods\nbg_cutoff = 100  # days\nss_cutoff = 80  # days","key":"N4T8kZCLTM"},{"type":"outputs","id":"e3YfUKV2m5gjOFq-xGeQj","children":[],"key":"NDseS8rO09"}],"key":"LBWk5DOl0P"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Here, we loop through all grid points and do the same analysis as before, storing the results in the empty arrays we just created.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"v9FTnh6WLM"}],"key":"wHrWMNZaPp"}],"key":"csxH7QcgYX"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"for i in range(dlat * dlon):\n    # Extract time series for current gridpoint\n    series = data_reshaped[:, i]\n\n    # Define sampling interval (daily data)\n    sampling_interval = 1\n\n    # Calculate mean and center the series\n    mean_value = np.mean(series)\n    centered_series = series - mean_value\n\n    # Compute FFT frequencies and convert to periods\n    freqs = np.fft.fftfreq(len(centered_series), sampling_interval)\n    # Handle division by zero (set zero frequency to infinity)\n    periods = np.where(freqs != 0, 1 / np.abs(freqs), np.inf)\n\n    # Compute Fourier coefficients and power spectrum\n    fourier_coeffs = np.fft.fft(centered_series)\n    amplitud = np.abs(fourier_coeffs)\n    power = (amplitud ** 2)\n\n    # Normalize power spectrum by total power and scale by series variance\n    normalized_power = (power/np.sum(power)) * np.var(centered_series)\n    # Total explained variance of the centered series\n    exp_var = (normalized_power / np.var(centered_series)) * 100.\n\n    # mask to extract different bands\n    mask_AC = np.where((np.abs(periods) >= ac_period[0]) &\n                       (periods <= ac_period[1]))\n    mask_IS = np.where((np.abs(periods) >= is_period[0]) &\n                       (periods <= is_period[1]))\n    mask_IA = np.where((np.abs(periods) >= ia_period[0]) &\n                       (periods <= ia_period[1]))\n\n    mask_BG = np.where(np.abs(periods) >= bg_cutoff)\n    mask_SS = np.where(np.abs(periods) <= ss_cutoff)\n\n    # Compute variances for each band\n    var_AC[i] = np.nansum(normalized_power[mask_AC])\n    var_IS[i] = np.nansum(normalized_power[mask_IS])\n    var_IA[i] = np.nansum(normalized_power[mask_IA])\n    var_BG[i] = np.nansum(normalized_power[mask_BG])\n    var_SS[i] = np.nansum(normalized_power[mask_SS])\n\n    # Compute explained variances for each band\n    exp_var_AC[i] = np.nansum(exp_var[mask_AC])\n    exp_var_IS[i] = np.nansum(exp_var[mask_IS])\n    exp_var_IA[i] = np.nansum(exp_var[mask_IA])\n    exp_var_BG[i] = np.nansum(exp_var[mask_BG])\n    exp_var_SS[i] = np.nansum(exp_var[mask_SS])\n","key":"ZmHh2BOWdp"},{"type":"outputs","id":"Rta-ASSNqEku_nxqFRhWr","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stderr","text":"/tmp/ipykernel_4106/2317136713.py:15: RuntimeWarning: divide by zero encountered in divide\n  periods = np.where(freqs != 0, 1 / np.abs(freqs), np.inf)\n"},"key":"FyfYbbHCS6"}],"key":"GO72xlKeKd"}],"key":"REGoK9l6Ro"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Reshape the results back to (latitude, longitude) for plotting:","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"lYkvvYl8Bo"}],"key":"RQEJl1GBgp"}],"key":"tAHZKUVnw0"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"var_AC = var_AC.reshape(dlat, dlon)\nvar_IS = var_IS.reshape(dlat, dlon)\nvar_IA = var_IA.reshape(dlat, dlon)\nvar_BG = var_BG.reshape(dlat, dlon)\nvar_SS = var_SS.reshape(dlat, dlon)\n\nexp_var_AC = exp_var_AC.reshape(dlat, dlon)\nexp_var_IS = exp_var_IS.reshape(dlat, dlon)\nexp_var_IA = exp_var_IA.reshape(dlat, dlon)\nexp_var_BG = exp_var_BG.reshape(dlat, dlon)\nexp_var_SS = exp_var_SS.reshape(dlat, dlon)\n\n# Compute standard deviations\ntotal_std = np.std(data_array, axis=0)\nstd_AC = np.sqrt(var_AC)\nstd_IS = np.sqrt(var_IS)\nstd_IA = np.sqrt(var_IA)\nstd_BG = np.sqrt(var_BG)\nstd_SS = np.sqrt(var_SS)","key":"Jgt6FMltCI"},{"type":"outputs","id":"EeHckhnwfPUTKnNRGPqxL","children":[],"key":"NjDi6s4pBZ"}],"key":"dhOOeaiAGs"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Plots","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"sSA0FvnShG"}],"identifier":"plots","label":"Plots","html_id":"plots","implicit":true,"key":"CPWNH2rsVp"}],"key":"rcj8F69kTS"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fig = plt.figure(figsize=(10, 5), layout='constrained')\nax = plt.subplot(111, projection=projPC)\nplot = ax.pcolormesh(uwind_ncep_ncar.lon, uwind_ncep_ncar.lat, exp_var_AC, vmin=0, vmax=90)\nax.coastlines()\nax.gridlines(draw_labels=True, alpha=0.7)\nplt.colorbar(plot, orientation='horizontal', label='Explained variance (%)')\nplt.title('Annual Cycle')","key":"VJDNGzdEDb"},{"type":"outputs","id":"oXbsR_SvrNN_BikzAZStO","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1000x500 with 2 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"de8598fbf0b3e5078e507693265631ab","path":"/spectral-analysis-cookbook/_preview/25/build/de8598fbf0b3e5078e507693265631ab.png"}}},"key":"NpA9MEq1sK"}],"key":"errFgR8bEa"}],"key":"ehtePz8YaG"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fig = plt.figure(figsize=(10, 5), layout='constrained')\nax = plt.subplot(111, projection=projPC)\nplot = ax.pcolormesh(uwind_ncep_ncar.lon, uwind_ncep_ncar.lat, exp_var_IS, vmin=0, vmax=90)\nax.coastlines()\nax.gridlines(draw_labels=True, alpha=0.7)\nplt.colorbar(plot, orientation='horizontal', label='Explained variance (%)')\nplt.title('Intra-Seasonal Variability [20-90 days]')","key":"MJi6r2tpj7"},{"type":"outputs","id":"iIrOzjUj4nrhhv2pngZh1","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1000x500 with 2 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"01706df8c02c61f8af672d5405251745","path":"/spectral-analysis-cookbook/_preview/25/build/01706df8c02c61f8af672d5405251745.png"}}},"key":"siZ5OjDUwn"}],"key":"ScVsmv9mAN"}],"key":"v7pxMhy7A3"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fig = plt.figure(figsize=(10, 5), layout='constrained')\nax = plt.subplot(111, projection=projPC)\nplot = ax.pcolormesh(uwind_ncep_ncar.lon, uwind_ncep_ncar.lat, exp_var_IA, vmin=0, vmax=90)\nax.coastlines()\nax.gridlines(draw_labels=True, alpha=0.7)\nplt.colorbar(plot, orientation='horizontal', label='Explained variance (%)')\nplt.title('Interannual Variability [2-7 years]')","key":"LA1aFW60zz"},{"type":"outputs","id":"itgaOW0t-4jANWj2abN_x","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1000x500 with 2 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"f62537d73ff306befe0fd84ecfe1e4ea","path":"/spectral-analysis-cookbook/_preview/25/build/f62537d73ff306befe0fd84ecfe1e4ea.png"}}},"key":"e8PDXzf5qK"}],"key":"EmYoTG46O5"}],"key":"jqNrxiu3i3"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fig = plt.figure(figsize=(10, 5), layout='constrained')\nax = plt.subplot(111, projection=projPC)\nplot = ax.pcolormesh(uwind_ncep_ncar.lon, uwind_ncep_ncar.lat, exp_var_BG, vmin=0, vmax=90)\nax.coastlines()\nax.gridlines(draw_labels=True, alpha=0.7)\nplt.colorbar(plot, orientation='horizontal', label='Explained variance (%)')\nplt.title('Background [>100 days]')","key":"XURpjLQZzZ"},{"type":"outputs","id":"NKCJdgNaVUGoVkFqtZG1U","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1000x500 with 2 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"c0aeea3e43de4c43b87c0b2dbb673e4b","path":"/spectral-analysis-cookbook/_preview/25/build/c0aeea3e43de4c43b87c0b2dbb673e4b.png"}}},"key":"kJd2YQm8iL"}],"key":"PHXcvdckwk"}],"key":"ugamTxD40z"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fig = plt.figure(figsize=(10, 5), layout='constrained')\nax = plt.subplot(111, projection=projPC)\nplot = ax.pcolormesh(uwind_ncep_ncar.lon, uwind_ncep_ncar.lat, exp_var_SS, vmin=0, vmax=90)\nax.coastlines()\nax.gridlines(draw_labels=True, alpha=0.7