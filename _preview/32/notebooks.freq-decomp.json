nIUe34","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"b8fede013ad402077f42d7b40d4f9511","path":"/spectral-analysis-cookbook/_preview/32/build/b8fede013ad402077f42d7b40d4f9511.png"}}},"key":"Ls8ki82GG9"}],"key":"Z5vB0s2aYn"}],"key":"BPMDqvPbOR"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"We need to center the data by removing its time mean.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"ILXeiBMB1A"}],"key":"k7UQmJd4H2"}],"key":"aFhQ7xU2ix"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"centered_series = uwind_ei - uwind_ei.mean(dim='time')","key":"R3LAHxLTlw"},{"type":"outputs","id":"AZ0VU_8I41iUb7FBmJ1cL","children":[],"key":"DIZQJFNIQ9"}],"key":"q84TGwdiDe"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"centered_series.plot()","key":"UWae1FuwHP"},{"type":"outputs","id":"H-rA2hGwSgXiP6eWYB0VV","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"edefd7de69873a7b57996201c2f3933a","path":"/spectral-analysis-cookbook/_preview/32/build/edefd7de69873a7b57996201c2f3933a.png"}}},"key":"Yd0Z9qnXNt"}],"key":"icxalN16tm"}],"key":"DSEqJA6ebF"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"We now perform the FFT, also computing the explained variance in percent.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"xTBn4ONg6h"}],"key":"j3sBlnUEWZ"}],"key":"qSt50hNNsy"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"sampling_interval = 1  # Assuming daily data, so 1 day between samples\n\nfreqs = np.fft.fftfreq(len(centered_series), sampling_interval)\n# Handle division by zero (set zero frequency to infinity)\nperiods = np.where(freqs != 0, 1 / np.abs(freqs), np.inf)\n\n# Compute Fourier coefficients and power spectrum\nfourier_coeffs = np.fft.fft(centered_series)\namplitude = np.abs(fourier_coeffs)\npower = (amplitude ** 2)\n\n# Normalize power spectrum by total power and scale by series variance\nnormalized_power = (power/np.sum(power)) * centered_series.var().compute().values\n# Total explained variance of the centered series\nexp_var = (normalized_power / centered_series.var().compute().values) * 100.","key":"OfV11WdZaZ"},{"type":"outputs","id":"uQfJj_hCju3veb_stynWN","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stderr","text":"/tmp/ipykernel_4038/537958354.py:5: RuntimeWarning: divide by zero encountered in divide\n  periods = np.where(freqs != 0, 1 / np.abs(freqs), np.inf)\n"},"key":"QA4mS75Skd"}],"key":"obJHeeMpLj"}],"key":"bfrZFkuDWw"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"plt.plot(periods,  exp_var, color='k')\nplt.xscale('log')\nplt.yscale('log')\nplt.xlim(1e1, 1.5e4)\nplt.ylim(1e-4, 3e0)\nplt.axvline(365.25, color='r', linestyle='--', label='365 days', zorder=-1)\nplt.axvline(365.25/2, color='b', linestyle='--', label=f'{365.25/2} days', zorder=-1)\nplt.axvline(365.25/3, color='y', linestyle='--', label=f'{365.25/3} days', zorder=-1)\nplt.axvline(365.25/4, color='g', linestyle='--', label=f'{365.25/4} days', zorder=-1)\nplt.xlabel('Days')\nplt.ylabel('Explained variance')\nplt.legend()","key":"Bbc323zVjW"},{"type":"out