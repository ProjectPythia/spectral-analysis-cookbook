],"key":"q7YsuZ9See"},{"type":"text","value":": >100 days (low-frequency variability)","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"PlW99F2Xkr"}],"key":"KDThOkPbme"}],"key":"FS84jo6DpG"},{"type":"listItem","spread":true,"position":{"start":{"line":8,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"paragraph","children":[{"type":"strong","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"Subseasonal (SS)","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"R0F2zMEBQ2"}],"key":"eyraQkQBBP"},{"type":"text","value":": <80 days (high-frequency variability)","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"y6yNIMnhun"}],"key":"IBFEbRMeKr"}],"key":"sIul8kbzsi"}],"key":"ijbaVzqcNr"},{"type":"paragraph","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"In detail, the method is:","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"v4BfdmImXi"}],"key":"EEkEn5ZeKR"},{"type":"list","ordered":true,"start":1,"spread":false,"position":{"start":{"line":11,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"For each grid point, extract time series and center by removing the mean","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"GIDIKcW6Re"}],"key":"hXfcFpXWt6"}],"key":"ReXrX4DQg1"},{"type":"listItem","spread":true,"position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Apply FFT to compute frequency spectrum and convert to period domain","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"bnzyWn1Mb1"}],"key":"Xf3wjNdxDR"}],"key":"HVDUBVNp6Y"},{"type":"listItem","spread":true,"position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Calculate normalized power spectrum scaled by variance","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"OCWTlEi9vP"}],"key":"COQcy7Ooam"}],"key":"kNYwRhxZwN"},{"type":"listItem","spread":true,"position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Apply frequency masks to isolate different bands","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"key":"OMOMIRGxba"}],"key":"VL0qrDHnm7"}],"key":"R7l8hYEYhn"},{"type":"listItem","spread":true,"position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Compute variance and explained variance (%) for each band","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"i1dppbd2Q0"}],"key":"pOk4wpTR2U"}],"key":"zLR9SGfj5J"}],"key":"GRQGcL97b8"}],"key":"xXlkobjK4S"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"As an example from the single location, we can compute the explained variance associated with the annual cycle, giving us about 12%:","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"kiMOsFj67E"}],"key":"HFK49Pckd6"}],"key":"oQI0VVm99n"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# mask to extract different bands\nac_period = (364, 366)  # days\nmask_AC = np.where((np.abs(periods) >= ac_period[0]) &\n                    (periods <= ac_period[1]))\n\n# Compute explained variances for each band\nexp_var_AC = np.nansum(exp_var[mask_AC])\nexp_var_AC","key":"lDCDmu65IM"},{"type":"outputs","id":"1V-9hUY3HHmOp98xEJeF_","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":10,"metadata":{},"data":{"text/plain":{"content":"np.float32(0.1229185)","content_type":"text/plain"}}},"key":"BHjainOFx8"}],"key":"vf3BtU2gG6"}],"key":"TaCdhwVnpd"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"uwind_ncep_ncar.uwnd.shape","key":"oFtSRpDwEj"},{"type":"outputs","id":"H3KGwYKnZJRqNlRE36SvE","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":11,"metadata":{},"data":{"text/plain":{"content":"(17167, 2, 25, 144)","content_type":"text/plain"}}},"key":"iG5lPJoBTm"}],"key":"wgSJCtLnOL"}],"key":"k0YtwlQ4k6"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Set up variables and empty arrays:","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"ttRamjd0Yb"}],"key":"leAl5a0kex"}],"key":"lpcxfLCNyn"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"data_array = uwind_ncep_ncar.isel(level=0).uwnd.values\n\n# Get the shape of the data array\ndtime, dlat, dlon = data_array.shape\n\n# Reshape data to 2D array: (time, space) for easier processing\ndata_reshaped = data_array.reshape(dtime, dlat * dlon)\n\n# Variance for different frequency bands\nvar_AC = np.zeros(dlat * dlon) * np.nan  # Annual Cycle\nvar_IS = np.zeros(dlat * dlon) * np.nan  # Intra-Seasonal Cycle\nvar_IA = np.zeros(dlat * dlon) * np.nan  # Inter-Annual Cycle\nvar_BG = np.zeros(dlat * dlon) * np.nan  # Background (longer than 100 days)\nvar_SS = np.zeros(dlat * dlon) * np.nan  # Subseasonal (shorter than 80 days)\n\n\n# Explained variance for different frequency bands\nexp_var_AC = np.zeros(dlat * dlon) * np.nan  # Annual Cycle\nexp_var_IS = np.zeros(dlat * dlon) * np.nan  # Intra-Seasonal\nexp_var_IA = np.zeros(dlat * dlon) * np.nan  # Inter-Annual Cycle\n\n# Background (longer than 100 days)\nexp_var_BG = np.zeros(dlat * dlon) * np.nan\n# Subseasonal (shorter than 80 days)\nexp_var_SS = np.zeros(dlat * dlon) * np.nan\n\n# Annual, Intra-Seasonal, Inter-annual periods in days\nac_period = (364, 366)  # days\nis_period = (20, 90)  # days\nia_period = (2*365.25, 7*365.25)  # days\n\n# Background and Subseasonal cutoff periods\nbg_cutoff = 100  # days\nss_cutoff = 80  # days","key":"UszBMRl0WV"},{"type":"outputs","id":"S5Ng2fNuXRMWqHX3W5F4t","children":[],"key":"T3yFE7njX8"}],"key":"R36EGKPDPC"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Here, we loop through all grid points and do the same analysis as before, storing the results in the empty arrays we just created.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Cq8rRD9HuP"}],"key":"bU7vIufXo1"}],"key":"uH2y7ctcdP"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"for i in range(dlat * dlon):\n    # Extract time series for current gridpoint\n    series = data_reshaped[:, i]\n\n    # Define sampling interval (daily data)\n    sampling_interval = 1\n\n    # Calculate mean and center the series\n    mean_value = np.mean(series)\n    centered_series = series - mean_value\n\n    # Compute FFT frequencies and convert to periods\n    freqs = np.fft.fftfreq(len(centered_series), sampling_interval)\n    # Handle division by zero (set zero frequency to infinity)\n    periods = np.where(freqs != 0, 1 / np.abs(freqs), np.inf)\n\n    # Compute Fourier coefficients and power spectrum\n    fourier_coeffs = np.fft.fft(centered_series)\n    amplitud = np.abs(fourier_coeffs)\n    power = (amplitud ** 2)\n\n    # Normalize power spectrum by total power and scale by series variance\n    normalized_power = (power/np.sum(power)) * np.var(centered_series)\n    # Total explained variance of the centered series\n    exp_var = (normalized_power / np.var(centered_series)) * 100.\n\n    # mask to extract different bands\n    mask_AC = np.where((np.abs(periods) >= ac_period[0]) &\n                       (periods <= ac_period[1]))\n    mask_IS = np.where((np.abs(periods) >= is_period[0]) &\n                       (periods <= is_period[1]))\n    mask_IA = np.where((np.abs(periods) >= ia_period[0]) &\n                       (periods <= ia_period[1]))\n\n    mask_BG = np.where(np.abs(periods) >= bg_cutoff)\n    mask_SS = np.where(np.abs(periods) <= ss_cutoff)\n\n    # Compute variances for each band\n    var_AC[i] = np.nansum(normalized_power[mask_AC])\n    var_IS[i] = np.nansum(normalized_power[mask_IS])\n    var_IA[i] = np.nansum(normalized_power[mask_IA])\n    var_BG[i] = np.nansum(normalized_power[mask_BG])\n    var_SS[i] = np.nansum(normalized_power[mask_SS])\n\n    # Compute explained variances for each band\n    exp_var_AC[i] = np.nansum(exp_var[mask_AC])\n    exp_var_IS[i] = np.nansum(exp_var[mask_IS])\n    exp_var_IA[i] = np.nansum(exp_var[mask_IA])\n    exp_var_BG[i] = np.nansum(exp_var[mask_BG])\n    exp_var_SS[i] = np.nansum(exp_var[mask_SS])\n","key":"vjv35uvuSg"},{"type":"outputs","id":"HH8TqOFvCOK-ct5bMAEVJ","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stderr","text":"/tmp/ipykernel_4038/2317136713.py:15: RuntimeWarning: divide by zero encountered in divide\n  periods = np.where(freqs != 0, 1 / np.abs(freqs), np.inf)\n"},"key":"jg8lExjRPk"}],"key":"jDEsgsD2ab"}],"key":"LPEbNun1wq"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Reshape the results back to (latitude, longitude) for plotting:","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"HsjLmvDapf"}],"key":"m9IR1UtTcN"}],"key":"bPs0dJyeC3"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"var_AC = var_AC.reshape(dlat, dlon)\nvar_IS = var_IS.reshape(dlat, dlon)\nvar_IA = var_IA.reshape(dlat, dlon)\nvar_BG = var_BG.reshape(dlat, dlon)\nvar_SS = var_SS.reshape(dlat, dlon)\n\nexp_var_AC = exp_var_AC.reshape(dlat, dlon)\nexp_var_IS = exp_var_IS.reshape(dlat, dlon)\nexp_var_IA = exp_var_IA.reshape(dlat, dlon)\nexp_var_BG = exp_var_BG.reshape(dlat, dlon)\nexp_var_SS = exp_var_SS.reshape(dlat, dlon)\n\n# Compute standard deviations\ntotal_std = np.std(data_array, axis=0)\nstd_AC = np.sqrt(var_AC)\nstd_IS = np.sqrt(var_IS)\nstd_IA = np.sqrt(var_IA)\nstd_BG = np.sqrt(var_BG)\nstd_SS = np.sqrt(var_SS)","key":"TZTsoHRheO"},{"type":"outputs","id":"C-UmiKYDxtgN3r3sIne0d","children":[],"key":"AxE5xJaJ96"}],"key":"nOT0R3rpkm"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Plots","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"jLMRmghGDZ"}],"identifier":"plots","label":"Plots","html_id":"plots","implicit":true,"key":"zh8sO5Ziou"}],"key":"wFRB4JZ4Xg"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fig = plt.figure(figsize=(10, 5), layout='constrained')\nax = plt.subplot(111, projection=projPC)\nplot = ax.pcolormesh(uwind_ncep_ncar.lon, uwind_ncep_ncar.lat, exp_var_AC, vmin=0, vmax=90)\nax.coastlines()\nax.gridlines(draw_labels=True, alpha=0.7)\nplt.colorbar(plot, orientation='horizontal', label='Explained variance (%)')\nplt.title('Annual Cycle')","key":"WPLWsORzXV"},{"type":"outputs","id":"PwpwCKhJ6lJTfjntlNZHG","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1000x500 with 2 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"de8598fbf0b3e5078e507693265631ab","path":"/spectral-analysis-cookbook/_preview/32/build/de8598fbf0b3e5078e507693265631ab.png"}}},"key":"yRDgo8CZdE"}],"key":"nfGyIUekWK"}],"key":"g0QKWf4dXq"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fig = plt.figure(figsize=(10, 5), layout='constrained')\nax = plt.subplot(111, projection=projPC)\nplot = ax.pcolormesh(uwind_ncep_ncar.lon, uwind_ncep_ncar.lat, exp_var_IS, vmin=0, vmax=90)\nax.coastlines()\nax.gridlines(draw_labels=True, alpha=0.7)\nplt.colorbar(plot, orientation='horizontal', label='Explained variance (%)')\nplt.title('Intra-Seasonal Variability [20-90 days]')","key":"pJJqLytoUS"},{"type":"outputs","id":"TOJUn0kYQG729PZGT-Aay","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1000x500 with 2 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"01706df8c02c61f8af672d5405251745","path":"/spectral-analysis-cookbook/_preview/32/build/01706df8c02c61f8af672d5405251745.png"}}},"key":"GXR8eYSsz6"}],"key":"tEtaQW8VIg"}],"key":"DCPjRm7BuG"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fig = plt.figure(figsize=(10, 5), layout='constrained')\nax = plt.subplot(111, projection=projPC)\nplot = ax.pcolormesh(uwind_ncep_ncar.lon, uwind_ncep_ncar.lat, exp_var_IA, vmin=0, vmax=90)\nax.coastlines()\nax.gridlines(draw_labels=True, alpha=0.7)\nplt.colorbar(plot, orientation='horizontal', label='Explained variance (%)')\nplt.title('Interannual Variability [2-7 years]')","key":"z9WXPwMoWy"},{"type":"outputs","id":"Ztbs9j7afymr0XC2n1hWI","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"tex