angle), np.cos(angle)]]\n)\n\nn_samples = 10_000\ncloud = rotation @ np.diag(scales) @ rng.standard_normal((2, n_samples)) + center[:, None]\n\n\nplt.figure(figsize=(5, 5))\nplt.plot(cloud[0], cloud[1], \"o\", markersize=2, alpha=0.5, color='k')\nplt.plot(center[0], center[1], \"o\", color=\"red\", markersize=3, label=\"Center\")\nplt.legend()\nplt.axis(\"equal\")\nplt.title(\"2D Gaussian Cloud\");","key":"QzB04J1r8R"},{"type":"outputs","id":"DehNLIwIUtmwNIglV5IOS","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 500x500 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"1b311c98a11c382669df124bb9747d62","path":"/spectral-analysis-cookbook/_preview/27/build/1b311c98a11c382669df124bb9747d62.png"}}},"key":"nPFWPy0yOc"}],"key":"JyTvFrgNW3"}],"key":"QVmzpHurz4"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Analysis","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"BIACrDbbQT"}],"identifier":"analysis","label":"Analysis","html_id":"analysis","implicit":true,"key":"Y0vsyV5gsV"}],"key":"LXPdmbMzGU"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Remove mean:","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"MuM10bLIuH"}],"key":"GgdrwvWzAA"}],"key":"aLMHS4AuBa"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"","key":"rWd7gYVreZ"},{"type":"outputs","id":"e0hibmWMq-OHSvgVEk92R","children":[],"key":"JJW7PztGBh"}],"key":"VDe8VvydMN"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"mean = cloud.mean(axis=1, keepdims=True)\ndetrended_cloud = cloud - mean","key":"Nk2wdMfLgY"},{"type":"outputs","id":"tnpKnEb1oEmsOThVYn_zd","children":[],"key":"R3IsYuDXCp"}],"key":"dro1UmDYB6"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Construct covariance matrices","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Llc34qqbzY"}],"key":"oWiKaNZ6kE"}],"key":"zn9EbA3tB6"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"cov_matrix_1 = (detrended_cloud @ detrended_cloud.T) / n_samples\ncov_matrix_2 = (detrended_cloud.T @ detrended_cloud) / n_samples\n\nprint(\"Covariance matrix 1 shape:\", cov_matrix_1.shape)\nprint(\"Covariance matrix 2 shape:\", cov_matrix_2.shape)","key":"pddL7Vg39Z"},{"type":"outputs","id":"Ci82oCNFr_x05C9HWEM7V","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Covariance matrix 1 shape: (2, 2)\nCovariance matrix 2 shape: (10000, 10000)\n"},"key":"jxrYPyXssh"}],"key":"v7Vvp6V07s"}],"key":"pXgtULksHF"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Since matrix 1 is much smaller, we will find its eigenvalues.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Nqwp0r8K05"}],"key":"FdyWwJSGK9"}],"key":"lGuBpVKeUP"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"eigen_val, eigen_vect = np.linalg.eig(cov_matrix_1)","key":"Jzvg9DJx5v"},{"type":"outputs","id":"kpdGio0eDHrDALNwzCcZO","children":[],"key":"JGx2f0B1ZC"}],"key":"QpsdI5trK8"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"eigen_val","key":"vSvt