,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"We will perform the FFT at one location first. Let’s select a location over the eastern Indian Ocean, indicated by the X in the above plot.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"vvB0Lx5giC"}],"key":"xGeYb63mNj"}],"key":"gEHtJUm6bF"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"uwind_ei = uwind_ncep_ncar.uwnd.isel(level=0).sel(lat=0, lon=90)\nuwind_ei.plot()","key":"wCmiCMVepT"},{"type":"outputs","id":"1OuWLVXtZ_fK6zbwwbPAc","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"b8fede013ad402077f42d7b40d4f9511","path":"/spectral-analysis-cookbook/_preview/21/build/b8fede013ad402077f42d7b40d4f9511.png"}}},"key":"S1vXXg1LGK"}],"key":"jDTK9esbh0"}],"key":"SkE0cuhckA"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"We need to center the data by removing its time mean.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"bih1kderlj"}],"key":"uw4MBDT29A"}],"key":"Xdke7ePFdX"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"centered_series = uwind_ei - uwind_ei.mean(dim='time')","key":"eWGiU3EgJD"},{"type":"outputs","id":"AQW-YwYYTOnzH8A8vyP3M","children":[],"key":"JYpMHwTFGd"}],"key":"Y0gER4JGCk"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"centered_series.plot()","key":"S4aSJTt2Xg"},{"type":"outputs","id":"5ub4dI-NTiC7jnl_mHsaR","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metada