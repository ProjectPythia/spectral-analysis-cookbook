"line":1,"column":1}},"key":"EKlwNs6tpd"}],"key":"WKeLrgoj3B"}],"key":"UMSdHLAL3b"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"uwind_ei = uwind_ncep_ncar.uwnd.isel(level=0).sel(lat=0, lon=90)\nuwind_ei.plot()","key":"M4B9QaDyH1"},{"type":"outputs","id":"lIl6h8OHdijm66HPy2fNg","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"b8fede013ad402077f42d7b40d4f9511","path":"/spectral-analysis-cookbook/_preview/21/build/b8fede013ad402077f42d7b40d4f9511.png"}}},"key":"VX8SceMFyU"}],"key":"tzYlRXaCgc"}],"key":"rK5yqOMFKj"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"We need to center the data by removing its time mean.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"ecS1l347lJ"}],"key":"tw0HfGOzOA"}],"key":"KlXmNayJLx"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"centered_series = uwind_ei - uwind_ei.mean(dim='time')","key":"mIHDcA6JkM"},{"type":"outputs","id":"6spnif_9poVP2j2L4Ubkq","children":[],"key":"W3ErNW9E03"}],"key":"mMZREGqmFY"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"centered_series.plot()","key":"WNlEO8c57v"},{"type":"outputs","id":"B8ILb9Xq60erbvDneeekr","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"edefd7de69873a7b57996201c2f3933a","path":"/spectral-analysis-cookbook/_preview/21/build/edefd7de69873a7b57996201c2f3933a.png"}}},"key":"cjRlSOXsxs"}],"key":"gAnhlrkfcD"}],"key":"Xa9oHJQV5E"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"We now perform the FFT, also computing the explained variance in percent.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Od8NtZuaNu"}],"key":"eIpRLmkTQK"}],"key":"HSFYFxCVV5"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"sampling_interval = 1  # Assuming daily data, so 1 day between samples\n\nfreqs = np.fft.fftfreq(len(centered_series), sampling_interval)\n# Handle division by zero (set zero frequency to infinity)\nperiods = np.where(freqs != 0, 1 / np.abs(freqs), np.inf)\n\n# Compute Fourier coefficients and power spectrum\nfourier_coeffs = np.fft.fft(centered_series)\namplitude = np.abs(fourier_coeffs)\npower = (amplitude ** 2)\n\n# Normalize power spectrum by total power and scale by series variance\nnormalized_power = (power/np.sum(power)) * centered_series.var().compute().values\n# Total explained variance of the centered series\nexp_var = (normalized_power / centered_series.var().compute().values) * 100.","key":"R5FkJO2av1"},{"type":"outputs","id":"yXOHMHWip0_Ngu65nf8Rn","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stderr","text":"/tmp/ipykernel_3886/537958354.py:5: RuntimeWarning: divide by zero encountered in divide\n  periods = np.where(freqs != 0, 1 / np.abs(freqs), np.inf)\n"},"key":"RD6583EVqW"}],"key":"sRioXaPRQC"}],"key":"QcQOcwb7eg"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"plt.plot(periods,  exp_var, color='k')\nplt.xscale('log')\nplt.yscale('log')\nplt.xlim(1e1, 1.5e4)\nplt.ylim(1e-4, 3e0)\nplt.axvline(365.25, color='r', linestyle='--', label='365 days', zorder=-1)\nplt.axvline(365.25/2, colo