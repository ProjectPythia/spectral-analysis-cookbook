","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"nv5piJwyv4"}],"identifier":"generate-data","label":"Generate data","html_id":"generate-data","implicit":true,"key":"Fo0twYVUTg"}],"key":"B65m9YKrM3"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"sns.set_theme(style=\"whitegrid\", context=\"notebook\", font_scale=1.2)\nrng = np.random.default_rng(7)\n\ncenter = np.array([2.0, 1.0])\nscales = np.array([2.0, 0.6])\nangle = np.pi / 4\n\nrotation = np.array(\n    [[np.cos(angle), -np.sin(angle)],\n     [np.sin(angle), np.cos(angle)]]\n)\n\nn_samples = 10_000\ncloud = rotation @ np.diag(scales) @ rng.standard_normal((2, n_samples)) + center[:, None]\n\n\nplt.figure(figsize=(5, 5))\nplt.plot(cloud[0], cloud[1], \"o\", markersize=2, alpha=0.5, color='k')\nplt.plot(center[0], center[1], \"o\", color=\"red\", markersize=3, label=\"Center\")\nplt.legend()\nplt.axis(\"equal\")\nplt.title(\"2D Gaussian Cloud\");","key":"GkiYVzEsQF"},{"type":"outputs","id":"R8KuB3lXp3LSmB_QAAv55","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 500x500 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"1b311c98a11c382669df124bb9747d62","path":"/spectral-analysis-cookbook/_preview/21/build/1b311c98a11c382669df124bb9747d62.png"}}},"key":"Wf4xYpa8iO"}],"key":"mK6uW5aWPm"}],"key":"QUNhMdDBCB"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Analysis","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"p2n7piwMgg"}],"identifier":"analysis","label":"Analysis","html_id":"analysis","implicit":true,"key":"jZQvWsmeSk"}],"key":"iave7bhaHs"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Remove mean:","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"VnnToLbDTF"}],"key":"DBIcxUNhiF"}],"key":"WjOWn7WAmd"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"","key":"GDppXV4K0U"},{"type":"outputs","id":"_no-f4E2sVeV9z0PtYHnm","children":[],"key":"X9r0YFC4x1"}],"key":"PV9I9csRKL"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"mean = cloud.mean(axis=1, keepdims=True)\ndetrended_cloud = cloud - mean","key":"HXFs8DYuq2"},{"type":"outputs","id":"JKy400BY4hw4bFBFrm-Xv","children":[],"key":"qkDCeehKUY"}],"key":"roYx5074OH"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Construct covariance matrices","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"ty2p6Q0kdp"}],"key":"cEUJV7jwb7"}],"key":"kAYn6e3l7y"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"cov_matrix_1 = (detrended_cloud @ detrended_cloud.T) / n_samples\ncov_matrix_2 = (detrended_cloud.T @ detrended_cloud) / n_samples\n\nprint(\"Covariance matrix 1 shape:\", cov_matrix_1.shape)\nprint(\"Covariance matrix 2 shape:\", cov_matrix_2.shape)","key":"lY84ZWOZdj"},{"type":"outputs","id":"4twhxYuxnH66M8DLx1bvz","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Covariance matrix 1 shape: (2, 2)\nCovariance matrix 2 shape: (10000, 10000)\n"},"key":"Dxla1eKG10"}],"key":"LxwNEfvZx5"}],"key":"qeTFFzxvEJ"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Since matrix 1 is much smaller, we will find its eigenvalues.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"z4nHEGImMG"}],"key":"oQ0nFK4R9N"}],"key":"LaqbASHiAG"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"eigen_val, eigen_vect = np.linalg.eig(cov_matrix_1)","key":"iOd7xD3bxP"},{"type":"outputs","id":"MM1ByzrkdSzemtJBDitBt","children":[],"key":"wUZ1aNl8Pi"}],"key":"VY3xMPMFlw"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"eigen_val","key":"hb26mXTC0M"},{"type":"outputs","id":"Uml3INWxbxOSB0LTAo1k_","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":6,"metadata":{},"data":{"text/plain":{"content":"array([3.95439111, 0.35316582])","content_type":"text/plain"}}},"key":"bSAPjk2da6"}],"key":"DMr2woqJkr"}],"key":"vBZeVNeSwh"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Visualize results","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"gEeuK27zme"}],"identifier":"visualize-results","label":"Visualize results","html_id":"visualize-results","implicit":true,"key":"eH5MomL9Mq"}],"key":"oCdPWrJRSw"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"eigen_vect","key":"qfywEiHIdv"},{"type":"outputs","id":"nlWNgG61UIcd83WwAWzKk","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":7,"metadata":{},"data":{"text/plain":{"content":"array([[ 0.70990989, -0.70429252],\n       [ 0.70429252,  0.70990989]])","content_type":"text/plain"}}},"key":"yuZH7aRHNZ"}],"key":"ZzBUcUXZdd"}],"key":"rf4b3H5C9N"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fig, (ax_left, ax_right) = plt.subplots(1, 2, figsize=(10, 4),\n                                        sharex=True, sharey=True)\n\nax_left.scatter(cloud[0], cloud[1], s=2, c=\"black\", alpha=0.35)\nax_left.set_title(\"Generated cloud\")\n\nax_right.scatter(cloud[0], cloud[1], s=2, c=\"black\", alpha=0.35)\nax_right.set_title(\"PCA axes\")\n\nfor direction, length in zip(eigen_vect.T, eigen_val):\n    endpoint = mean[:, 0] + direction * np.sqrt(length)\n    ax_right.arrow(\n        mean[0, 0],\n        mean[1, 0],\n        endpoint[0] - mean[0, 0],\n        endpoint[1] - mean[1, 0],\n        color=\"magenta\",\n        linewidth=1.5,\n        length_includes_head=True,\n        head_width=0.15,\n        head_length=0.2,\n        zorder=5\n    )\n\nfor ax in (ax_left, ax_right):\n    ax.plot(center[0], center[1], \"o\", color=\"red\", markersize=3, label=\"Center\")\n    ax.set_aspect(\"equal\")\n    ax.set_xlim(-6, 8)\n    ax.set_ylim(-6, 8)\n","key":"ZYZtHmi48G"},{"type":"outputs","id":"9z33KGPGgIieOwi7vvEs2","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1000x400 with 2 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"a3d1a3771ea9529eb0bb6c65168e2d93","path":"/spectral-analysis-cookbook/_preview/21/build/a3d1a3771ea9529eb0bb6c65168e2d93.png"}}},"key":"OAKsJFquEK"}],"key":"pfAqqBRnSb"}],"key":"RLC1as3Bd0"},{"type":"block","kind":"notebook-content","children":[{"type":"thematicBreak","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"ogiBlk633R"}],"key":"mzO42Xi4Qb"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Summary","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"l5wDtKw1Ds"}],"identifier":"summary","label":"Summary","h