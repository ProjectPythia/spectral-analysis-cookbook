10_000\ncloud = rotation @ np.diag(scales) @ rng.standard_normal((2, n_samples)) + center[:, None]\n\n\nplt.figure(figsize=(5, 5))\nplt.plot(cloud[0], cloud[1], \"o\", markersize=2, alpha=0.5, color='k')\nplt.plot(center[0], center[1], \"o\", color=\"red\", markersize=3, label=\"Center\")\nplt.legend()\nplt.axis(\"equal\")\nplt.title(\"2D Gaussian Cloud\");","key":"o63PZICbFI"},{"type":"outputs","id":"fER2MkJe5Z36GFZ4AOFhn","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 500x500 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"1b311c98a11c382669df124bb9747d62","path":"/spectral-analysis-cookbook/build/1b311c98a11c382669df124bb9747d62.png"}}},"key":"SsBPsowBiR"}],"key":"KshAvwKuHg"}],"key":"qZbDrNHolN"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Analysis","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"beCpla2qkp"}],"identifier":"analysis","label":"Analysis","html_id":"analysis","implicit":true,"key":"PMOcIU4bcO"}],"key":"KB0IVVCSbH"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Remove mean:","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"AGc5gKeX6P"}],"key":"FisXmvH7MU"}],"key":"lgUMkHlkdy"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"","key":"pxkiOhmzQz"},{"type":"outputs","id":"jGTAfPWbF8-038LXYXlZ5","children":[],"key":"e1mut11t9X"}],"key":"ihom3I9NpH"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"mean = cloud.mean(axis=1, keepdims=True)\ndetrended_cloud = cloud - mean","key":"mTfg36CxaG"},{"type":"outputs","id":"EeXc_m4HZP5z_AHGnLN7y","children":[],"key":"xPo3heXtJj"}],"key":"mPlOghpSFy"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Construct covariance matrices","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"JXtncAFYDm"}],"key":"O4Vzdpf1dP"}],"key":"zWoGH14SA4"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"cov_matrix_1 = (detrended_cloud @ detrended_cloud.T) / n_samples\ncov_matrix_2 = (detrended_cloud.T @ detrended_cloud) / n_samples\n\nprint(\"Covariance matrix 1 shape:\", cov_matrix_1.shape)\nprint(\"Covariance matrix 2 shape:\", cov_matrix_2.shape)","key":"Bs5Vtn9tmP"},{"type":"outputs","id":"yECQ_9lqonH7psLkCyxmr","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Covariance matrix 1 shape: (2, 2)\nCovariance matrix 2 shape: (10000, 10000)\n"},"key":"ZyA8kJjTN5"}],"key":"Uj1sticOxT"}],"key":"awMEQTJALH"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Since matrix 1 is much smaller, we will find its eigenvalues.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"y0CoILQRsb"}],"key":"VbIxuJP0BY"}],"key":"Kiq95pk60R"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"eigen_val, eigen_vect = np.linalg.eig(cov_matrix_1)","key":"eMSSYTUNCN"},{"type":"outputs","id":"eRG9dyPYwS49e0yi0kMUS","children":[],"key":"L8cArfO0gU"}],"key":"GmXkWkHY4V"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"eigen_val","key":"gioQWScHIB"},{"type":"outputs","id":"J_0iBkJcARFp5UcPcLXS0","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":6,"metadata":{},"data":{"text/plain":{"content":"array([3.95439111, 0.35316582])","content_type":"text/plain"}}},"key":"gKmWUVbUQT"}],"key":"kzOc5ZC0GW"}],"key":"JvRHC1WVtR"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Visualize results","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"XODxSyTsv6"}],"identifier":"visualize-results","label":"Visualize results","html_id":"visualize-results","implicit":true,"key":"gnlVIOx6nL"}],"key":"CRvw7jSYiq"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"eigen_vect","key":"dTSZ3eRiDF"},{"type":"outputs","id":"tpyNLUEDdqaa9BthKRg-c","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":7,"metadata":{},"data":{"text/plain":{"content":"array([[ 0.70990989, -0.70429252],\n       [ 0.70429252,  0.70990989]])","content_type":"text/plain"}}},"key":"lcX1LvLIco"}],"key":"IAyYW9KgYZ"}],"key":"HGBNO1uO5W"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fig, (ax_left, ax_right) = plt.subplots(1, 2, figsize=(10, 4),\n                                        sharex=True, sharey=True)\n\nax_left.scatter(cloud[0], cloud[1], s=2, c=\"black\", alpha=0.35)\nax_left.set_title(\"Generated cloud\")\n\nax_right.scatter(cloud[0], cloud[1], s=2, c=\"black\", alpha=0.35)\nax_right.set_title(\"PCA axes\")\n\nfor direction, length in zip(eigen_vect.T, eigen_val):\n    endpoint = mean[:, 0] + direction * np.sqrt(length)\n    ax_right.arrow(\n        mean[0, 0],\n        mean[1, 0],\n        endpoint[0] - mean[0, 0],\n        endpoint[1] - mean[1, 0],\n        color=\"magenta\",\n        linewidth=1.5,\n        length_includes_head=True,\n        head_width=0.15,\n        head_length=0.2,\n        zorder=5\n    )\n\nfor ax in (ax_left, ax_right):\n    ax.plot(center[0], center[1], \"o\", color=\"red\", markersize=3, label=\"Center\")\n    ax.set_aspect(\"equal\")\n    ax.set_xlim(-6, 8)\n    ax.set_ylim(-6, 8)\n","key":"NZzREXbmrF"},{"type":"outputs","id":"eB-hmwCZ1QLTAUlXRwORZ","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1000x400 with 2 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"a3d1a3771ea9529eb0bb6c65168e2d93","path":"/spectral-analysis-cookbook/build/a3d1a3771ea9529eb0bb6c65168e2d93.png"}}},"key":"Xe6YFF70VP"}],"key":"MGzcNOXcXN"}],"key":"nzfWU56cMg"},{"type":"block","kind":"notebook-content","children":[{"type":"thematicBreak","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"JtVb8BPdGy"}],"key":"RrbayREPJf"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Summary","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"IJhyPRJEJa"}],"identifier":"summary","label":"Summary","html_id":"summary","implicit":true,"key":"PM5pHTfJ9S"},{"type":"paragraph","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"children":[{"type":"text","value":"TBD","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"Dg1uFnwcUN"}],"key":"Cg5eUAH3h5"},{"type":"heading","depth":3,"position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"What’s next?","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"ZcFZyZEdJa"}],"identifier":"whats-next","label":"What’s next?","html_id":"whats-next","implicit":true,"key":"rhDwbPYQfO"},{"type":"paragraph","po