ildren":[{"type":"code","lang":"python","executable":true,"value":"sns.set_theme(style=\"whitegrid\", context=\"notebook\", font_scale=1.2)\nrng = np.random.default_rng(7)\n\ncenter = np.array([2.0, 1.0])\nscales = np.array([2.0, 0.6])\nangle = np.pi / 4\n\nrotation = np.array(\n    [[np.cos(angle), -np.sin(angle)],\n     [np.sin(angle), np.cos(angle)]]\n)\n\nn_samples = 10_000\ncloud = rotation @ np.diag(scales) @ rng.standard_normal((2, n_samples)) + center[:, None]\n\n\nplt.figure(figsize=(5, 5))\nplt.plot(cloud[0], cloud[1], \"o\", markersize=2, alpha=0.5, color='k')\nplt.plot(center[0], center[1], \"o\", color=\"red\", markersize=3, label=\"Center\")\nplt.legend()\nplt.axis(\"equal\")\nplt.title(\"2D Gaussian Cloud\");","key":"nxyzf0TYFL"},{"type":"outputs","id":"Rr8y-F6qA2MJ43li9WtXw","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 500x500 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"1b311c98a11c382669df124bb9747d62","path":"/spectral-analysis-cookbook/build/1b311c98a11c382669df124bb9747d62.png"}}},"key":"r74BFjqKRA"}],"key":"GcBDC4HZhZ"}],"key":"XtlV8RpS7J"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Analysis","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"z9E4NSwk6Z"}],"identifier":"analysis","label":"Analysis","html_id":"analysis","implicit":true,"key":"RG2AQYXJDQ"}],"key":"zbbmhAdbgs"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Remove mean:","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"F1oL9DFEAL"}],"key":"LB8aeWKbLi"}],"key":"bAIt67ixdO"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"","key":"hbgIau5NrI"},{"type":"outputs","id":"tL5-SnPjzuo_-sstAoMK-","children":[],"key":"mQyFYYRONC"}],"key":"BR4pGjc9ee"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"mean = cloud.mean(axis=1, keepdims=True)\ndetrended_cloud = cloud - mean","key":"HHzomly9R6"},{"type":"outputs","id":"xpgrxSbzrk-ZAGueA1qb9","children":[],"key":"I4MWTs8uAj"}],"key":"BACMAZSr07"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Construct covariance matrices","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Ngpg1jJny7"}],"key":"yhQCRE8IEQ"}],"key":"afUsksXLBo"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"cov_matrix_1 = (detrended_cloud @ detrended_cloud.T) / n_samples\ncov_matrix_2 = (detrended_cloud.T @ detrended_cloud) / n_samples\n\nprint(\"Covariance matrix 1 shape:\", cov_matrix_1.shape)\nprint(\"Covariance matrix 2 shape:\", cov_matrix_2.shape)","key":"iB1KqvrckM"},{"type":"outputs","id":"cpVTCzy0EtEtzqqGI_3FY","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Covariance matrix 1 shape: (2, 2)\nCovariance matrix 2 shape: (10000, 10000)\n"},"key":"vfuuipmRsN"}],"key":"X7nLAghUOT"}],"key":"CLxC4rHORb"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Since matrix 1 is much smaller, we will find its eigenvalues.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"HN9GQMfD9l"}],"key":"YcuacQsrJl"}],"key":"zOdt3W2IwS"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":