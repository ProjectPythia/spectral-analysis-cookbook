:"tui3MfZSQr"}],"key":"RRZiwK7qVI"},{"type":"tableCell","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[],"key":"JhY8B28Pnm"}],"key":"dVE9t0RTJQ"}],"key":"whNqUteXCo"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"paragraph","children":[{"type":"strong","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"Time to learn","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"ZwXR8RZk7z"}],"key":"KkI9TjSoou"},{"type":"text","value":": 10 minutes","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"shcwrIrIu3"}],"key":"St4EsCOCzw"}],"key":"Lt9uMVEYHy"}],"key":"IcExKYMRCM"}],"key":"JHHsaDjjKu"},{"type":"block","kind":"notebook-content","children":[{"type":"thematicBreak","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"SfXkR3Psmm"}],"key":"gkbATyrcTq"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Imports","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"C3U8mlx7d6"}],"identifier":"imports","label":"Imports","html_id":"imports","implicit":true,"key":"Pp9PWpjzfV"}],"key":"MeN3DUT6bC"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import matplotlib.pyplot as plt\nimport numpy as np\nimport seaborn as sns","key":"b16IOqairD"},{"type":"outputs","id":"2WuAzgq60BnYURPM61-5X","children":[],"key":"qosZa9LSg1"}],"key":"mZiou7u8QV"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Generate data","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"INoApsB5gS"}],"identifier":"generate-data","label":"Generate data","html_id":"generate-data","implicit":true,"key":"gsglgndKv0"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"We first create the data: a 2D cloud sampled from a Gaussian distribution.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"bcbqm61ppn"}],"key":"QBvciXtfMv"}],"key":"Y8k79z4cf5"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"sns.set_theme(style=\"whitegrid\", context=\"notebook\", font_scale=1.2)\nrng = np.random.default_rng(7)\n\ncenter = np.array([2.0, 1.0])\nscales = np.array([2.0, 0.6])\nangle = np.pi / 4\n\nrotation = np.array(\n    [[np.cos(angle), -np.sin(angle)],\n     [np.sin(angle), np.cos(angle)]]\n)\n\nn_samples = 10_000\ncloud = rotation @ np.diag(scales) @ rng.standard_normal((2, n_samples)) + center[:, None]\n\n\nplt.figure(figsize=(5, 5))\nplt.plot(cloud[0], cloud[1], \"o\", markersize=2, alpha=0.5, color='k')\nplt.plot(center[0], center[1], \"o\", color=\"red\", markersize=3, label=\"Center\")\nplt.legend()\nplt.axis(\"equal\")\nplt.title(\"2D Gaussian Cloud\");","key":"yk06s8md3A"},{"type":"outputs","id":"dz_37ogyZcS-WmbznA7NB","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 500x500 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"8dee5d8921491aaf77ca5dcbd8edaeb1","path":"/spectral-analysis-cookbook/build/8dee5d8921491aaf77ca5dcbd8edaeb1.png"}}},"key":"QcXZzkkNME"}],"key":"AJZRg3aGPd"}],"key":"DyjAgGda7V"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"For some geophysical context, we could think of this as some variable measured at two locations (e.g., air temperature measured at two weather stations or salinity measured at two buoys). If those locations are nearby, we expect some correlation between the values measured at each. The goal of an EOF analysis is to find the direction in the above 2-dimensional plane that maximizes the variance explained in the data. As explained in the ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"AAm1jtQoP7"},{"type":"link","url":"/notebooks/eofs-3d","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"3D EOFs notebook","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"LRen9CgxAT"}],"urlSource":"./eofs-3d.ipynb","dataUrl":"/notebooks.eofs-3d.json","internal":true,"protocol":"file","key":"eAqrp1lld6"},{"type":"text","value":" and the separate ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"MEph7TfPYM"},{"type":"link","url":"https://projectpythia.org/eofs-cookbook/","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"EOFs Cookbook","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"aBFXMZfmjE"}],"urlSource":"https://projectpythia.org/eofs-cookbook/","key":"IWZFcWMsXP"},{"type":"text","value":", this is done by computing the covariance matrix of the data and finding its eigenvectors/values.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"NXVnkoWBOd"}],"key":"jPcLOhTzzA"}],"key":"SvU198BESf"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Analysis","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"n0KSR9O3HR"}],"identifier":"analysis","label":"Analysis","html_id":"analysis","implicit":true,"key":"je0YOGLm4d"}],"key":"vg9z3v5btG"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Center data by removing the mean:","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"eSCUn82qqR"}],"key":"Z7E2W8uyOu"}],"key":"PRCXRi2FFm"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"mean = cloud.mean(axis=1, keepdims=True)\ncentered_cloud = cloud - mean","key":"D78nXN8Rso"},{"type":"outputs","id":"nXMNk0O7H77aDtYQKQt8K","children":[],"key":"V7059XDvKb"}],"key":"UtvCvwtN4D"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Now, construct the covariance matrix. There are two options here, as described in more detail in the ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"n6Z8Z2BV4Q"},{"type":"link","url":"/notebooks/eofs-3d","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"3D EOFs notebook","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"pjGJNrjLjI"}],"urlSource":"./eofs-3d.ipynb","dataUrl":"/notebooks.eofs-3d.json","internal":true,"protocol":"file","key":"XTtS8re4Wa"},{"type":"text","value":", depending on the order of multiplication.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"GPfE6o6N9h"}],"key":"MxGpgvdzrQ"}],"key":"FX8GClHI2D"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"cov_matrix_1 = (centered_cloud @ centered_cloud.T) / n_samples\ncov_matrix_2 = (centered_cloud.T @ centered_cloud) / n_samples\n\nprint(\"Covariance matrix 1 shape:\", cov_matrix_1.shape)\nprint(\"Covariance matrix 2 shape:\", cov_matrix_2.shape)","key":"aMYgaKZp1y"},{"type":"outputs","id":"gjxgjfZyR20Tqp8CZ-Zvt","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Covariance matrix 1 shape: (2, 2)\nCovariance matrix 2 shape: (10000, 10000)\n"},"key":"I7OTs4rXNh"}],"key":"rxGxn7wAUc"}],"key":"xpve1Ce89e"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Since matrix 1 is much smaller, it is much more computationally efficient to find its eigenvalues.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"JYDXN21MHZ"}],"key":"oa1jWCCq9k"}],"key":"YJedKbmTrS"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"eigen_val, eigen_vect = np.linalg.eig(cov_matrix_1)","key":"sK5ofDHZZ6"},{"type":"outputs","id":"tE3COMvRfN6LVmCLVM4OB","children":[],"key":"YI1RAcJw2n"}],"key":"MlOLIAntPZ"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"eigen_val, eigen_vect","key":"liz18hEhFE"},{"type":"outputs","id":"KHDPjRGJqCJDAFegDZWsk","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":6,"metadata":{},"data":{"text/plain":{"content":"(array([3.95439111, 0.35316582]),\n array([[ 0.70990989, -0.70429252],\n        [ 0.70429252,  0.70990989]]))","content_type":"text/plain"}}},"key":"Q6tr9za4Ok"}],"key":"GArUormnT7"}],"key":"IBtEvNlfvy"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"The eigenvectors tells us the directions, and the eigenvalues the magnitudes.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"mswYAjsH0Y"}],"key":"I4WbHveY3g"}],"key":"qNbxyythXA"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Visualize results","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Ubi9MghnMP"}],"identifier":"visualize-results","label":"Visualize results","html_id":"visualize-results","implicit":true,"key":"ZgewqIvxnu"}],"key":"URvtOFm6Ed"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fig, (ax_left, ax_right) = plt.subplots(1, 2, figsize=(10, 4),\n                                        sharex=True, sharey=True)\n\nax_left.scatter(cloud[0], cloud[1], s=2, c=\"black\", alpha=0.35)\nax_left.set_title(\"Generated cloud\")\n\nax_right.scatter(cloud[0], cloud[1], s=2, c=\"black\", alpha=0.35)\nax_right.set_title(\"PCA axes\")\n\nfor direction, length in zip(eigen_vect.T, eigen_val):\n    endpoint = mean[:, 0] + direction * np.sqrt(length)\n    ax_right.arrow(\n        mean[0, 0],\n        mean[1, 0],\n        endpoint[0] - mean[0, 0],\n        endpoint[1] - mean[1, 0],\n        color=\"magenta\",\n        linewidth=1.5,\n        length_includes_head=True,\n        head_width=0.15,\n        head_length=0.2,\n        zorder=5\n    )\n\nfor ax in (ax_left, ax_right):\n    ax.plot(center[0], center[1], \"o\", color=\"red\", markersize=3, label=\"Center\")\n    ax.set_aspect(\"equal\")\n    ax.set_xlim(-6, 8)\n    ax.set_ylim(-6, 8)","key":"U369KaiBJ2"},{"type":"outputs","id":"BOH5ORKHjOO3wUYeNsBLK","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1000x400 with 2 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"e4d79707b9870f56048ca4aa43414dcd","path":"/spectral-analysis-cookbook/build/e4d79707b9870f56048ca4aa43414dcd.png"}}},"key":"tVEPiwvytJ"}],"key":"hnVt34UJno"}],"key":"aPw1xQ6Usc"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"The leading “mode of variability” (i.e., the larger of the two arrows) points in the direction that the data varies the most. In other words, if the data were projected onto the line parallel to the larger arrow, becoming 1-dimensional, it would have the largest 1-dimensional variance possbile for this data. For atmospheric/ocean data in 3 dimensions (latitude, longitude, time), instead of having 2-dimensional eigenvectors, you have (lat ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"PdtkVTKwBe"},{"type":"inlineMath","value":"\\times","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mo>×</mo></mrow><annotation encoding=\"application/x-tex\">\\times</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:0.6667em;vertical-align:-0.0833em;\"></span><span class=\"mord\">×</span></span></span></span>","key":"cQlJjUXoWP"},{"type":"text","value":" lon)-dimensional eigenvectors, so the arrows become maps.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"IRGUuSSmid"}],"key":"r9iV0AB1tT"}],"key":"nc8rKufccv"},{"type":"block","kind":"notebook-content","children":[{"type":"thematicBreak","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"d7wToqTwjT"}],"key":"zJnnTGjToQ"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Summary","position":{"start":{"line":1,"column":1},"end":{"line":