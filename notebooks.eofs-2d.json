":7,"column":1},"end":{"line":7,"column":1}},"key":"cMv5FDskQj"}],"key":"DvNwl31fi2"},{"type":"text","value":": 15 minutes","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"fEClgMF5mm"}],"key":"YtMzKr33g6"}],"key":"dPMJCFeMSm"}],"key":"thQh7BDYDP"}],"key":"EQOcoABuV1"},{"type":"block","kind":"notebook-content","children":[{"type":"thematicBreak","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"cGGWXTHBp8"}],"key":"v0JpK5MWps"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Imports","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"fYvrQo7wtz"}],"identifier":"imports","label":"Imports","html_id":"imports","implicit":true,"key":"y7IrSmdWhx"}],"key":"iNHeOs3TxU"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import matplotlib.pyplot as plt\nimport numpy as np\nimport seaborn as sns","key":"CwuWgwJ8kW"},{"type":"outputs","id":"3__VMMsS4R2bYPfgjOkbO","children":[],"key":"saWUi6GvWS"}],"key":"qmf4PNf5r0"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Generate data","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"CdPSVaz8Kd"}],"identifier":"generate-data","label":"Generate data","html_id":"generate-data","implicit":true,"key":"g8wP5lOIaS"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"We first create the data: a 2D cloud sampled from a Gaussian distribution.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"O0BMWLt8uL"}],"key":"UVB6A1HF3v"}],"key":"cytOSKXmtf"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"sns.set_theme(style=\"whitegrid\", context=\"notebook\", font_scale=1.2)\nrng = np.random.default_rng(7)\n\ncenter = np.array([2.0, 1.0])\nscales = np.array([2.0, 0.6])\nangle = np.pi / 4\n\nrotation = np.array(\n    [[np.cos(angle), -np.sin(angle)],\n     [np.sin(angle), np.cos(angle)]]\n)\n\nn_samples = 10_000\ncloud = rotation @ np.diag(scales) @ rng.standard_normal((2, n_samples)) + center[:, None]\n\n\nplt.figure(figsize=(5, 5))\nplt.plot(cloud[0], cloud[1], \"o\", markersize=2, alpha=0.5, color='k')\nplt.plot(center[0], center[1], \"o\", color=\"red\", markersize=3, label=\"Center\")\nplt.legend()\nplt.axis(\"equal\")\nplt.title(\"2D Gaussian Cloud\");","key":"V37OW7NvVw"},{"type":"outputs","id":"WSQF7JIGl7Lyzn8h13Rxh","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 500x500 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"8dee5d8921491aaf77ca5dcbd8edaeb1","path":"/spectral-analysis-cookbook/build/8dee5d8921491aaf77ca5dcbd8edaeb1.png"}}},"key":"rwGvsmG0D8"}],"key":"MOLpyspdjx"}],"key":"aOrd3yGr9C"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"For some geophysical context, we could think of this as some variable measured at two locations (e.g., air temperature measured at two weather stations or salinity measured at two buoys). If those locations are nearby, we expect some correlation between the values measured at each. The goal of an EOF analysis is to find the direction in the above 2-dimensional plane that maximizes the variance explained in the data. As explained in the ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"WHPJrFHYBD"},{"type":"link","url":"/notebooks/eofs-3d","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"3D EOFs notebook","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"zI5ngYzYoD"}],"urlSource":"./07.eofs-3d.ipynb","dataUrl":"/notebooks.eofs-3d.json","internal":true,"protocol":"file","key":"LNlJ0w8TjL"},{"type":"text","value":" and the separate ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"mSydkw8mF1"},{"type":"link","url":"https://projectpythia.org/eofs-cookbook/","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"EOFs Cookbook","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"E2jE3IzWc8"}],"urlSource":"https://projectpythia.org/eofs-cookbook/","key":"yP2fsrPX25"},{"type":"text","value":", this is done by computing the covariance matrix of the data and finding its eigenvectors/values.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"C6HaOnh2YT"}],"key":"YNqBPd4hE2"}],"key":"Hi7BymM8GI"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Analysis","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"eh41Ancqbg"}],"identifier":"analysis","label":"Analysis","html_id":"analysis","implicit":true,"key":"xa2GK0k0GX"}],"key":"E3XSjVpVeC"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Center data by removing the mean:","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"oRCL2gUA6z"}],"key":"TXwRcTBAYj"}],"key":"lOHk9lSUr3"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"mean = cloud.mean(axis=1, keepdims=True)\ncentered_cloud = cloud - mean","key":"WKgS0QQp7O"},{"type":"outputs","id":"Vs32dpvIPb8FvP7F5U6w-","children":[],"key":"jTFVQ1f206"}],"key":"xn4ZGN1Hk2"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Now, construct the covariance matrix. There are two options here, as described in more detail in the ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"nCOIJyq9dQ"},{"type":"link","url":"/notebooks/eofs-3d","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"3D EOFs notebook","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Hu5FG3Ms3c"}],"urlSource":"./07.eofs-3d.ipynb","dataUrl":"/notebooks.eofs-3d.json","internal":true,"protocol":"file","key":"Q73mmpItsY"},{"type":"text","value":", depending on the order of multiplication.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"fnaFlzDDte"}],"key":"kZ72y0uho4"}],"key":"R1SujnRQAN"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"cov_matrix_1 = (centered_cloud @ centered_cloud.T) / n_samples\ncov_matrix_2 = (centered_cloud.T @ centered_cloud) / n_samples\n\nprint(\"Covariance matrix 1 shape:\", cov_matrix_1.shape)\nprint(\"Covariance matrix 2 shape:\", cov_matrix_2.shape)","key":"fLjqJ04Oo0"},{"type":"outputs","id":"0q74e3JiurANk7oPFDD2H","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Covariance matrix 1 shape: (2, 2)\nCovariance matrix 2 shape: (10000, 10000)\n"},"key":"hf8oPpQBF4"}],"key":"cif8mfelIz"}],"key":"WRYlRfD88t"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Since matrix 1 is much smaller, it is much more computationally efficient to find its eigenvalues.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"aHgC8xvSQ1"}],"key":"Ky64D1ysHY"}],"key":"o7N9pXwXAd"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"eigen_val, eigen_vect = np.linalg.eig(cov_matrix_1)","key":"yrFZhMGQ1a"},{"type":"outputs","id":"2c_6wIm5MFZxKie-ZcgBp","children":[],"key":"mPkBG49IA1"}],"key":"i9Mepo8T96"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"eigen_val, eigen_vect","key":"VXtdQuyriy"},{"type":"outputs","id":"7BYpw1j0OiS5S8jRpdpH1","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":6,"metadata":{},"data":{"text/plain":{"content":"(array([3.95439111, 0.35316582]),\n array([[ 0.70990989, -0.70429252],\n        [ 0.70429252,  0.70990989]]))","content_type":"text/plain"}}},"key":"CW3THVfQwz"}],"key":"QlQ7zizdP5"}],"key":"BSkuqvq6hX"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"The eigenvectors tells us the directions, and the eigenvalues the magnitudes.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"SXo2OdlKHw"}],"key":"zeeVMLiQvx"}],"key":"Wo7iUKjI0h"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Visualize results","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"K1IevJHEuY"}],"identifier":"visualize-results","label":"Visualize results","html_id":"visualize-results","implicit":true,"key":"dZASQ8D5Hr"}],"key":"JHFdTNlCiX"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fig, (ax_left, ax_right) = plt.subplots(1, 2, figsize=(10, 4),\n                                        sharex=True, sharey=True)\n\nax_left.scatter(cloud[0], cloud[1], s=2, c=\"black\", alpha=0.35)\nax_left.set_title(\"Generated cloud\")\n\nax_right.scatter(cloud[0], cloud[1], s=2, c=\"black\", alpha=0.35)\nax_right.set_title(\"PCA axes\")\n\nfor direction, length in zip(eigen_vect.T, eigen_val):\n    endpoint = mean[:, 0] + direction * np.sqrt(length)\n    ax_right.arrow(\n        mean[0, 0],\n        mean[1, 0],\n        endpoint[0] - mean[0, 0],\n        endpoint[1] - mean[1, 0],\n        color=\"magenta\",\n        linewidth=1.5,\n        length_includes_head=True,\n        head_width=0.15,\n        head_length=0.2,\n        zorder=5\n    )\n\nfor ax in (ax_left, ax_right):\n    ax.plot(center[0], center[1], \"o\", color=\"red\", markersize=3, label=\"Center\")\n    ax.set_aspect(\"equal\")\n    ax.set_xlim(-6, 8)\n    ax.set_ylim(-6, 8)","key":"h3C7WJrqRi"},{"type":"outputs","id":"6hdCCNi5fUig-zdcQgv5U","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1000x400 with 2 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"e4d79707b9870f56048ca4aa43414dcd","path":"/spectral-analysis-cookbook/build/e4d79707b9870f56048ca4aa43414dcd.png"}}},"key":"aQNNTgWBQS"}],"key":"Z8uVZceO74"}],"key":"tDgGOch3ap"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"The leading “mode of variability” (i.e., the larger of the two arrows) points in the direction that the data varies the most. In other words, if the data were projected onto the line parallel to the larger arrow, becoming 1-dimensional, it would have the largest 1-dimensional variance possbile for this data. For atmospheric/ocean data in 3 dimensions (latitude, longitude, time), instead of having 2-dimensional eigenvectors, you have (lat ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"q6nSYL4T2N"},{"type":"inlineMath","value":"\\times","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mo>×</mo></mrow><annotation encoding=\"application/x-tex\">\\times</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:0.6667em;vertical-align:-0.0833em;\"></span><span class=\"mord\">×</span></span></span></span>","key":"deSWxvh2Ql"},{"type":"text","value":" lon)-dimensional eigenvectors, so the arrows become maps.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"jdJXDbQ7Bj"}],"key":"D4LCLWSJS6"}],"key":"jTug8YWE0e"},{"type":"block","kind":"notebook-content","children":[{"type":"thematicBreak","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"DhHQrqjwAJ"}],"key":"fmmnJoN974"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Summary","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"PENWjQe19G"}],"identifier":"summary","label":"Summary","html_id":"summary","implicit":true,"key":"bBo3tHXpVV"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"We performed an EOF / PCA analysis on a synthetic 2D Gaussian cloud. After centering the data, we built its covariance matrix and computed its eigen-decomposition: the ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"Dqx2DZaXbr"},{"type":"strong","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"eigenvectors","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"xvApfJfVIk"}],"key":"A1j7kvRm3V"},{"type":"text","value":" point along the orthogonal directions of largest variability in the cloud, and the ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"UDFUelod0d"},{"type":"strong","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"eigenvalues","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"CfwLrtkwjI"}],"key":"BpTvjd0UOE"},{"type":"text","value":" measure how much variance each direction explains. Projecting the data onto the leading eigenvector gives a 1D representation that retains the maximum possible variance, which is the defining property of PCA. The exact same procedure generalizes to geophysical fields, where the eigenvectors become spatial maps (EOFs) and the projections become time series (principal components).","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"ACj5619Y2r"}],"key":"o0H7FcDzEU"},{"type":"heading","depth":3,"position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"What’s next?","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"Kf49L6BPj2"}],"identifier":"whats-next","label":"What’s next?","html_id":"whats-next","implicit":true,"key":"icP0dxfNI1"},{"type":"paragraph","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"We now scale this workflow up to space-time data. The next notebook, ","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"u1od8eyfeU"},{"type":"link","url":"/notebooks/eofs-3d","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"3D EOFs","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"ITqOg5RjNJ"}],"urlSource