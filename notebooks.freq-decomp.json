","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"b8fede013ad402077f42d7b40d4f9511","path":"/spectral-analysis-cookbook/build/b8fede013ad402077f42d7b40d4f9511.png"}}},"key":"uCKdrbTHUA"}],"key":"J5Bn3uMbhd"}],"key":"e2sjQU3Yjd"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"We need to center the data by removing its time mean.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"YwrNHVQH7j"}],"key":"oa2cBOHJ83"}],"key":"sTD3aRordZ"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"centered_series = uwind_ei - uwind_ei.mean(dim='time')","key":"yLcwc5lRmB"},{"type":"outputs","id":"aAqp7ztimF4LjbDAmF7E8","children":[],"key":"K0KiJhyjSB"}],"key":"DDWy5dkPBa"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"centered_series.plot()","key":"l28AGrtCyh"},{"type":"outputs","id":"YIPlpsgqhD6PZkpGl9WVd","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"edefd7de69873a7b57996201c2f3933a","path":"/spectral-analysis-cookbook/build/edefd7de69873a7b57996201c2f3933a.png"}}},"key":"hVTTcLxEbD"}],"key":"utc5nxDug4"}],"key":"zO3Wo4we7Z"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"We now perform the FFT, also computing the explained variance in percent.","position":{"start":{"line":1,"col