,  exp_var, color='k')\nplt.xscale('log')\nplt.yscale('log')\nplt.xlim(1e1, 1.5e4)\nplt.ylim(1e-4, 3e0)\nplt.axvline(365.25, color='r', linestyle='--', label='365 days', zorder=-1)\nplt.axvline(365.25/2, color='b', linestyle='--', label=f'{365.25/2} days', zorder=-1)\nplt.axvline(365.25/3, color='y', linestyle='--', label=f'{365.25/3} days', zorder=-1)\nplt.axvline(365.25/4, color='g', linestyle='--', label=f'{365.25/4} days', zorder=-1)\nplt.xlabel('Days')\nplt.ylabel('Explained variance')\nplt.legend()","key":"gD4jjvUOIR"},{"type":"outputs","id":"MID1uAop-txPfMKBowTg3","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"3cc94c48a3212b8a290cd646d3379dda","path":"/spectral-analysis-cookbook/build/3cc94c48a3212b8a290cd646d3379dda.png"}}},"key":"IxhReBVHCQ"}],"key":"NnPM4dC6Tr"}],"key":"i2znQltBKf"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"There are noticeable spectral peaks at fractions of one year.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"qdIRQ5NRhx"}],"key":"hR8gPacGvH"}],"key":"c8B96psndV"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Now, we will perform the FFT at every location in the dataset. Then, we will compute the explained variance over various spectral bands associated with different kinds of variability.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"F0MpqQC0Vw"}],"key":"SOUfDx3FD9"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"strong","position":{"start":{