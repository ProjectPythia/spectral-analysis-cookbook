","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"f5a23a0e5a663d1d0d5bc6f9717d621a","path":"/spectral-analysis-cookbook/build/f5a23a0e5a663d1d0d5bc6f9717d621a.png"}}},"key":"E3tXx7kgfo"}],"key":"ZtWefc5zrB"}],"key":"lUcd8CaCVT"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"We need to center the data by removing its time mean.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"uImSLOMGFf"}],"key":"kALWIvFMbh"}],"key":"nkqY8f7oD0"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"centered_series = uwind_ei - uwind_ei.mean(dim='time')","key":"wlDUNbvBFA"},{"type":"outputs","id":"jy1jJXyv1ZzCt0pSYhs8c","children":[],"key":"ISomDrD9ES"}],"key":"L7LUujstfh"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"centered_series.plot()","key":"fYoz6f2UKp"},{"type":"outputs","id":"lHWi4jlI0pz9mZNvZyGoD","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"8c999b06813560a7f1271594b1d7960b","path":"/spectral-analysis-cookbook/build/8c999b06813560a7f1271594b1d7960b.png"}}},"key":"RytGriU2RS"}],"key":"C8NbB0Ojb6"}],"key":"s7nQXlZc9S"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"We now perform the FFT, also computing the explained variance in percent.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"y4Wem4EZXH"}],"key":"noSUpmBRK1"}],"key":"MTCg3g0mHM"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"sampling_interval = 1  # Assuming daily data, so 1 day between samples\n\nfreqs = np.fft.fftfreq(len(centered_series), sampling_interval)\n# Handle division by zero (set zero frequency to infinity)\nperiods = np.where(freqs != 0, 1 / np.abs(freqs), np.inf)\n\n# Compute Fourier coefficients and power spectrum\nfourier_coeffs = np.fft.fft(centered_series)\namplitude = np.abs(fourier_coeffs)\npower = (amplitude ** 2)\n\n# Normalize power spectrum by total power and scale by series variance\nnormalized_power = (power/np.sum(power)) * centered_series.var().compute().values\n# Total explained variance of the centered series\nexp_var = (normalized_power / centered_series.var().compute().values) * 100.","key":"ryrMUPCGYQ"},{"type":"outputs","id":"M61GdeKNgAiZdM1zgTzbj","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stderr","text":"/tmp/ipykernel_4389/537958354.py:5: RuntimeWarning: divide by zero encountered in divide\n  periods = np.where(freqs != 0, 1 / np.abs(freqs), np.inf)\n"},"key":"RMLYMTeLMS"}],"key":"k5XiD53CPj"}],"key":"DVp4UsB1lb"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"plt.plot(periods,  exp_var, color='k')\nplt.xscale('log')\nplt.yscale('log')\nplt.xlim(1e1, 1.5e4)\nplt.ylim(1e-4, 3e0)\nplt.axvline(365.25, color='r', linestyle='--', label='365 days', zorder=-1)\nplt.axvline(365.25/2, color='b', linestyle='--', label=f'{365.25/2} days', zorder=-1)\nplt.axvline(365.25/3, color='y', linestyle='--', label=f'{365.25/3} days', zorder=-1)\nplt.axvline(365.25/4, color='g', linestyle='--', label=f'{365.25/4} days', zorder=-1)\nplt.xlabel('Days')\nplt.ylabel('Explained variance')\nplt.legend()","key":"RN34d11vrx"},{"type":"outputs","id":"GT7t8Kri34rvfCtz08