":1}},"children":[{"type":"text","value":"We will perform the FFT at one location first. Let’s select a location over the eastern Indian Ocean, indicated by the X in the above plot.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"iYwIYOKWqJ"}],"key":"Ye1n9dwxJS"}],"key":"S50PoAKAHx"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"uwind_ei = uwind_ncep_ncar.uwnd.isel(level=0).sel(lat=0, lon=90)\nuwind_ei.plot()","key":"YxbMbJBMpV"},{"type":"outputs","id":"RQL617ciGat3AFZGK4IlM","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"b8fede013ad402077f42d7b40d4f9511","path":"/spectral-analysis-cookbook/build/b8fede013ad402077f42d7b40d4f9511.png"}}},"key":"o4FPX5yVkY"}],"key":"kZuXpccXov"}],"key":"hKW6gcFBfg"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"We need to center the data by removing its time mean.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"zafoTHK4ut"}],"key":"uERIq9n9SE"}],"key":"OOupALgYWG"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"centered_series = uwind_ei - uwind_ei.mean(dim='time')","key":"vLxoLQ9bRN"},{"type":"outputs","id":"RIG_3oPX1wB0K85txRych","children":[],"key":"CU66oRNEYz"}],"key":"BN3VBQUkLc"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"centered_series.plot()","key":"mhEWB9zXkJ"},{"type":"outputs","id":"kI2ZmWwTWEXEiQjlZWNTT","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure 