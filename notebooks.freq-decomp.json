ock","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"projPC = ccrs.PlateCarree()\nfig = plt.figure(figsize=(10, 5), layout='constrained')\nax = plt.subplot(111, projection=projPC)\nuwind_ncep_ncar.uwnd.isel(level=0, time=0).plot(transform=projPC, cbar_kwargs={'orientation': 'horizontal'})\nax.scatter(90, 0, marker='x', color='k', s=50, transform=projPC, zorder=3)\nax.coastlines()\nax.gridlines(draw_labels=True, alpha=0.7)","key":"KDQp03ndwC"},{"type":"outputs","id":"8_WJRp0BCauKbN-_UloU1","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":4,"metadata":{},"data":{"text/plain":{"content":"<cartopy.mpl.gridliner.Gridliner at 0x7f9fc5327620>","content_type":"text/plain"}}},"key":"ESf2QgB1zw"},{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stderr","text":"/home/runner/micromamba/envs/cookbook-dev/lib/python3.14/site-packages/cartopy/io/__init__.py:242: DownloadWarning: Downloading: https://naturalearth.s3.amazonaws.com/110m_physical/ne_110m_coastline.zip\n  warnings.warn(f'Downloading: {url}', DownloadWarning)\n"},"key":"PXDqhIRBjX"},{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1000x500 with 2 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"4956a949c9c75d0ac8b5f4c0b8794acc","path":"/spectral-analysis-cookbook/build/4956a949c9c75d0ac8b5f4c0b8794acc.png"}}},"key":"ZhikYd5ocT"}],"key":"w0aDbXSFZn"}],"key":"HAFiITrWok"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"We will perform the FFT at one location first. Let’s select a location over the eastern Indian Ocean, indicated by the X in the above plot.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Sg92Qgowgp"}],"key":"SovtQmXxmF"}],"key":"PzxWeEzCZf"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"uwind_ei = uwind_ncep_ncar.uwnd.isel(level=0).sel(lat=0, lon=90)\nuwind_ei.plot()","key":"jtfOZIxOT7"},{"type":"outputs","id":"B8n8XwzWlWSRMc2IablHk","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"b8fede013ad402077f42d7b40d4f9511","path":"/spectral-analysis-cookbook/build/b8fede013ad402077f42d7b40d4f9511.png"}}},"key":"JFiTfSFYuh"}],"key":"jvlO3k1QqJ"}],"key":"hh3UUMf39w"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"We need to center the data by removing its time mean.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"bUz0OXZtFg"}],"key":"Jt5XvERkZF"}],"key":"RcpuO00oQl"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"centered_series = uwind_ei - uwind_ei.mean(dim='time')","key":"o1je6VoLBX"},{"type":"outputs","id":"GFiKj49V2XrTgOgNHmYzi","children":[],"key":"XR0LSdqL1r"}],"key":"wUubkj5JuR"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"centered_series.plot()","key":"ZTk6MShSX9"},{"type":"outputs","id":"MppPv3mDIGd01tHB3lsVn","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"edefd7de69873a7b57996201c2f3933a","path":"/spectral-analysis-cookbook/build/edefd7de69873a7b57996201c2f3933a.png"}}},"key":"A2wnPKiVBh"}],"key":"fmWDlQ00Gj"}],"key":"bJrK2bqYcN"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"We now perform the FFT, also computing the explained variance in percent.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"ZhIzUNk6nb"}],"key":"mqZAZai3u8"}],"key":"SlXvbzusQF"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"sampling_interval = 1  # Assuming daily data, so 1 day between samples\n\nfreqs = np.fft.fftfreq(len(centered_series), sampling_interval)\n# Handle division by zero (set zero frequency to infinity)\nperiods = np.where(freqs != 0, 1 / np.abs(freqs), np.inf)\n\n# Compute Fourier coefficients and power spectrum\nfourier_coeffs = np.fft.fft(centered_series)\namplitude = np.abs(fourier_coeffs)\npower = (amplitude ** 2)\n\n# Normalize power spectrum by total power and scale by series variance\nnormalized_power = (power/np.sum(power)) * centered_series.var().compute().values\n# Total explained variance of the centered series\nexp_var = (normalized_power / centered_series.var().compute().values) * 100.","key":"Cn1xTBi73C"},{"type":"outputs","id":"AIDkbU-tiiv5Sekbb9DQb","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stderr","text":"/tmp/ipykernel_3989/537958354.py:5: RuntimeWarning: divide by zero encountered in divide\n  periods = np.where(freqs != 0, 1 / np.abs(freqs), np.inf)\n"},"key":"JZdrjFUfuc"}],"key":"pdTxPASITP"}],"key":"DoanLTwy2M"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"plt.plot(periods,  exp_var, color='k')\nplt.xscale('log')\nplt.yscale('log')\nplt.xlim(1e1, 1.5e4)\nplt.ylim(1e-4, 3e0)\nplt.axvline(365.25, color='r', linestyle='--', label='365 days', zorder=-1)\nplt.axvline(365.25/2, color='b', linestyle='--', label=f'{365.25/2} days', zorder=-1)\nplt.axvline(365.25/3, color='y', linestyle='--', label=f'{365.25/3} days', zorder=-1)\nplt.axvline(365.25/4, color='g', linestyle='--', label=f'{365.25/4} days', zorder=-1)\nplt.xlabel('Days')\nplt.ylabel('Explained variance')\nplt.legend()","key":"Bi5PwkIlYc"},{"type":"outputs","id":"cWMns32R2zjtciEcE5rSW","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"3a9661c273c2ac2c0f3dc591cd52ae1e","path":"/spectral-analysis-cookbook/build/3a9661c273c2ac2c0f3dc591cd52ae1e.png"}}},"key":"HuhdsuJBse"}],"key":"QwppD2Nc9K"}],"key":"lvNJH1laB0"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"There are noticeable spectral peaks at fractions of one year.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"JZXtRJyjNx"}],"key":"NtalSJNPlo"}],"key":"MLdfZZDOVp"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Now, we will perform the FFT at every location in the dataset. Then, we will compute the explained variance over various spectral bands associated with different kinds of variability.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"mUi66LlnsE"}],"key":"eDvbuUskBv"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"strong","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"Frequency Bands:","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"BaDbCDLelF"}],"key":"igh1SV1KlE"}],"key":"Ci9X0NoiFz"},{"type":"list","ordered":false,