,  exp_var, color='k')\nplt.xscale('log')\nplt.yscale('log')\nplt.xlim(1e1, 1.5e4)\nplt.ylim(1e-4, 3e0)\nplt.axvline(365.25, color='r', linestyle='--', label='365 days', zorder=-1)\nplt.axvline(365.25/2, color='b', linestyle='--', label=f'{365.25/2} days', zorder=-1)\nplt.axvline(365.25/3, color='y', linestyle='--', label=f'{365.25/3} days', zorder=-1)\nplt.axvline(365.25/4, color='g', linestyle='--', label=f'{365.25/4} days', zorder=-1)\nplt.xlabel('Days')\nplt.ylabel('Explained variance')\nplt.legend()","key":"thcwkR0FHu"},{"type":"outputs","id":"14Vm6lrZtCC7I7fmH89X9","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"3a9661c273c2ac2c0f3dc591cd52ae1e","path":"/spectral-analysis-cookbook/build/3a9661c273c2ac2c0f3dc591cd52ae1e.png"}}},"key":"yCV9jWeFK2"}],"key":"I26KDoThtC"}],"key":"T8u6sGRKmA"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"There are noticeable spectral peaks at fractions of one year.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"PQcGJZk8Ay"}],"key":"hgIQhqm8IT"}],"key":"r816XYXAZ5"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Now, we will perform the FFT at every location in the dataset. Then, we will compute the explained variance over various spectral bands associated with different kinds of variability.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"CPeWovNwii"}],"key":"OaRPHLEyIn"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"strong","position":{"start":{