e":": >100 days (low-frequency variability)","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"l1MLYO6uce"}],"key":"aEWC2sFLk3"}],"key":"h0miXD2k6A"},{"type":"listItem","spread":true,"position":{"start":{"line":8,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"paragraph","children":[{"type":"strong","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"Subseasonal (SS)","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"W878CwgtSZ"}],"key":"YfnpbfQF64"},{"type":"text","value":": <80 days (high-frequency variability)","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"ZF08Mi9mTw"}],"key":"jXmYVowl68"}],"key":"iJpZIAVBPx"}],"key":"zAQvfoFdKA"},{"type":"paragraph","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"In detail, the method is:","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"xO7QC43EXI"}],"key":"uZ8cthTsFZ"},{"type":"list","ordered":true,"start":1,"spread":false,"position":{"start":{"line":11,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"For each grid point, extract time series and center by removing the mean","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"AYVfGHu2Q1"}],"key":"QM26f0oVDh"}],"key":"m1IoAJ37fS"},{"type":"listItem","spread":true,"position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Apply FFT to compute frequency spectrum and convert to period domain","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"eCteJNrSKO"}],"key":"rzZq0N97eP"}],"key":"TQ2Kwlye8N"},{"type":"listItem","spread":true,"position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Calculate normalized power spectrum scaled by variance","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"UkWsM7M5v6"}],"key":"nIKk80gdS2"}],"key":"oBvm2y6GEl"},{"type":"listItem","spread":true,"position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Apply frequency masks to isolate different bands","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"key":"Cv88nEQD5V"}],"key":"kSusIS3prT"}],"key":"blj8ctx9kF"},{"type":"listItem","spread":true,"position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Compute variance and explained variance (%) for each band","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"iNdQClOVOv"}],"key":"Ihdw17lCi9"}],"key":"jax36b89tO"}],"key":"pfUdfYEVVg"}],"key":"PSFV2ksx3h"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"As an example from the single location, we can compute the explained variance associated with the annual cycle, giving us about 12%:","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"nM7vM9ZSwJ"}],"key":"A9MFqL1SVB"}],"key":"hFcqPCibAo"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# mask to extract different bands\nac_period = (364, 366)  # days\nmask_AC = np.where((np.abs(periods) >= ac_period[0]) &\n                    (periods <= ac_period[1]))\n\n# Compute explained variances for each band\nexp_var_AC = np.nansum(exp_var[mask_AC])\nexp_var_AC","key":"TDa9qt7rdO"},{"type":"outputs","id":"tYNXes3Hv8Y0Aqa_-qfkh","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":10,"metadata":{},"data":{"text/plain":{"content":"np.float32(0.1229185)","content_type":"text/plain"}}},"key":"fHobeq7ubm"}],"key":"vqHZoZC7rc"}],"key":"oLPMYhgrUR"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"uwind_ncep_ncar.uwnd.shape","key":"cDN7cXQK9b"},{"type":"outputs","id":"a4ecRHOqHLQsubotrNJhp","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":11,"metadata":{},"data":{"text/plain":{"content":"(17167, 2, 25, 144)","content_type":"text/plain"}}},"key":"JdnEOj9zhW"}],"key":"moH6aIur4k"}],"key":"s0z7Y6ZAZa"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Set up variables and empty arrays:","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"wmg3E2m1oH"}],"key":"JDry5slqS6"}],"key":"e4iiLFzO24"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"data_array = uwind_ncep_ncar.isel(level=0).uwnd.values\n\n# Get the shape of the data array\ndtime, dlat, dlon = data_array.shape\n\n# Reshape data to 2D array: (time, space) for easier processing\ndata_reshaped = data_array.reshape(dtime, dlat * dlon)\n\n# Variance for different frequency bands\nvar_AC = np.zeros(dlat * dlon) * np.nan  # Annual Cycle\nvar_IS = np.zeros(dlat * dlon) * np.nan  # Intra-Seasonal Cycle\nvar_IA = np.zeros(dlat * dlon) * np.nan  # Inter-Annual Cycle\nvar_BG = np.zeros(dlat * dlon) * np.nan  # Background (longer than 100 days)\nvar_SS = np.zeros(dlat * dlon) * np.nan  # Subseasonal (shorter than 80 days)\n\n\n# Explained variance for different frequency bands\nexp_var_AC = np.zeros(dlat * dlon) * np.nan  # Annual Cycle\nexp_var_IS = np.zeros(dlat * dlon) * np.nan  # Intra-Seasonal\nexp_var_IA = np.zeros(dlat * dlon) * np.nan  # Inter-Annual Cycle\n\n# Background (longer than 100 days)\nexp_var_BG = np.zeros(dlat * dlon) * np.nan\n# Subseasonal (shorter than 80 days)\nexp_var_SS = np.zeros(dlat * dlon) * np.nan\n\n# Annual, Intra-Seasonal, Inter-annual periods in days\nac_period = (364, 366)  # days\nis_period = (20, 90)  # days\nia_period = (2*365.25, 7*365.25)  # days\n\n# Background and Subseasonal cutoff periods\nbg_cutoff = 100  # days\nss_cutoff = 80  # days","key":"T32iHN3kx4"},{"type":"outputs","id":"2jKintKNN8R4hp0EO0QyZ","children":[],"key":"ZRBVLoOan5"}],"key":"ZLAayOgnFb"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Here, we loop through all grid points and do the same analysis as before, storing the results in the empty arrays we just created.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"oOVEjN1fMi"}],"key":"sdYNGvht9h"}],"key":"Bhmx71w2vz"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"for i in range(dlat * dlon):\n    # Extract time series for current gridpoint\n    series = data_reshaped[:, i]\n\n    # Define sampling interval (daily data)\n    sampling_interval = 1\n\n    # Calculate mean and center the series\n    mean_value = np.mean(series)\n    centered_series = series - mean_value\n\n    # Compute FFT frequencies and convert to periods\n    freqs = np.fft.fftfreq(len(centered_series), sampling_interval)\n    # Handle division by zero (set zero frequency to infinity)\n    periods = np.where(freqs != 0, 1 / np.abs(freqs), np.inf)\n\n    # Compute Fourier coefficients and power spectrum\n    fourier_coeffs = np.fft.fft(centered_series)\n    amplitud = np.abs(fourier_coeffs)\n    power = (amplitud ** 2)\n\n    # Normalize power spectrum by total power and scale by series variance\n    normalized_power = (power/np.sum(power)) * np.var(centered_series)\n    # Total explained variance of the centered series\n    exp_var = (normalized_power / np.var(centered_series)) * 100.\n\n    # mask to extract different bands\n    mask_AC = np.where((np.abs(periods) >= ac_period[0]) &\n                       (periods <= ac_period[1]))\n    mask_IS = np.where((np.abs(periods) >= is_period[0]) &\n                       (periods <= is_period[1]))\n    mask_IA = np.where((np.abs(periods) >= ia_period[0]) &\n                       (periods <= ia_period[1]))\n\n    mask_BG = np.where(np.abs(periods) >= bg_cutoff)\n    mask_SS = np.where(np.abs(periods) <= ss_cutoff)\n\n    # Compute variances for each band\n    var_AC[i] = np.nansum(normalized_power[mask_AC])\n    var_IS[i] = np.nansum(normalized_power[mask_IS])\n    var_IA[i] = np.nansum(normalized_power[mask_IA])\n    var_BG[i] = np.nansum(normalized_power[mask_BG])\n    var_SS[i] = np.nansum(normalized_power[mask_SS])\n\n    # Compute explained variances for each band\n    exp_var_AC[i] = np.nansum(exp_var[mask_AC])\n    exp_var_IS[i] = np.nansum(exp_var[mask_IS])\n    exp_var_IA[i] = np.nansum(exp_var[mask_IA])\n    exp_var_BG[i] = np.nansum(exp_var[mask_BG])\n    exp_var_SS[i] = np.nansum(exp_var[mask_SS])\n","key":"Jt7HPjN5qf"},{"type":"outputs","id":"mEkNV9qfGunWizYlj_sz_","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stderr","text":"/tmp/ipykernel_4397/2317136713.py:15: RuntimeWarning: divide by zero encountered in divide\n  periods = np.where(freqs != 0, 1 / np.abs(freqs), np.inf)\n"},"key":"LemuCcZ9UR"}],"key":"AJbVUBDfPl"}],"key":"vybOlXovRO"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Reshape the results back to (latitude, longitude) for plotting:","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"i02EEyVtQJ"}],"key":"w8q0xVdbOI"}],"key":"dB2ZLqZQbb"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"var_AC = var_AC.reshape(dlat, dlon)\nvar_IS = var_IS.reshape(dlat, dlon)\nvar_IA = var_IA.reshape(dlat, dlon)\nvar_BG = var_BG.reshape(dlat, dlon)\nvar_SS = var_SS.reshape(dlat, dlon)\n\nexp_var_AC = exp_var_AC.reshape(dlat, dlon)\nexp_var_IS = exp_var_IS.reshape(dlat, dlon)\nexp_var_IA = exp_var_IA.reshape(dlat, dlon)\nexp_var_BG = exp_var_BG.reshape(dlat, dlon)\nexp_var_SS = exp_var_SS.reshape(dlat, dlon)\n\n# Compute standard deviations\ntotal_std = np.std(data_array, axis=0)\nstd_AC = np.sqrt(var_AC)\nstd_IS = np.sqrt(var_IS)\nstd_IA = np.sqrt(var_IA)\nstd_BG = np.sqrt(var_BG)\nstd_SS = np.sqrt(var_SS)","key":"M6DjUK4typ"},{"type":"outputs","id":"zSg1Yea8uFZ4yOSNwq15h","children":[],"key":"tat8Y0NOy0"}],"key":"c67dN82sgE"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Plots","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"jwNjqNcyBH"}],"identifier":"plots","label":"Plots","html_id":"plots","implicit":true,"key":"Ot6LUCbCLO"}],"key":"zT82ESqCL2"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fig = plt.figure(figsize=(10, 5), layout='constrained')\nax = plt.subplot(111, projection=projPC)\nplot = ax.pcolormesh(uwind_ncep_ncar.lon, uwind_ncep_ncar.lat, exp_var_AC, vmin=0, vmax=90)\nax.coastlines()\nax.gridlines(draw_labels=True, alpha=0.7)\nplt.colorbar(plot, orientation='horizontal', label='Explained variance (%)')\nplt.title('Annual Cycle')","key":"BR4ji4PqvU"},{"type":"outputs","id":"GsQxtXi1WCuh3dQvVWRUC","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 10