","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"f5a23a0e5a663d1d0d5bc6f9717d621a","path":"/spectral-analysis-cookbook/build/f5a23a0e5a663d1d0d5bc6f9717d621a.png"}}},"key":"ebFGenZDrw"}],"key":"iZL4gOqwtn"}],"key":"Am28v1rNhj"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"We need to center the data by removing its time mean.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"rDzNZfDStp"}],"key":"SgpDoWmbbk"}],"key":"UOFTAZdEpD"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"centered_series = uwind_ei - uwind_ei.mean(dim='time')","key":"cd2b7R1Sqf"},{"type":"outputs","id":"zSXiqzlYi6lPr_7pkKddj","children":[],"key":"ifucZGtsVZ"}],"key":"fLirbK5IMU"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"centered_series.plot()","key":"HX5Ab7sdkm"},{"type":"outputs","id":"JFiVrzwbINzPtGmwCpVvd","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"8c999b06813560a7f1271594b1d7960b","path":"/spectral-analysis-cookbook/build/8c999b06813560a7f1271594b1d7960b.png"}}},"key":"hiP1eOLpzF"}],"key":"XsKOeJzk8M"}],"key":"I2jboAGFus"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"We now perform the FFT, also computing the explained variance in percent.","position":{"start":{"line":1,"col