","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"f5a23a0e5a663d1d0d5bc6f9717d621a","path":"/spectral-analysis-cookbook/build/f5a23a0e5a663d1d0d5bc6f9717d621a.png"}}},"key":"TbpBVm8WOj"}],"key":"VYWcCdBt21"}],"key":"sfvt7TdeBq"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"We need to center the data by removing its time mean.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Cvmiff8BEu"}],"key":"NPYETRejJX"}],"key":"N1JJh36Dal"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"centered_series = uwind_ei - uwind_ei.mean(dim='time')","key":"SZ2jMAN1Cc"},{"type":"outputs","id":"aUQuRrMFAOk_lXw1KJ-0x","children":[],"key":"QXZPlRyVU0"}],"key":"FJvjUbvv59"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"centered_series.plot()","key":"hFuF66YxiW"},{"type":"outputs","id":"DuKH74buOe4YAhk8jhYDr","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"8c999b06813560a7f1271594b1d7960b","path":"/spectral-analysis-cookbook/build/8c999b06813560a7f1271594b1d7960b.png"}}},"key":"c5yolJuZrG"}],"key":"Ci8j2fThAj"}],"key":"iaj35TPSiq"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"We now perform the FFT, also computing the explained variance in percent.","position":{"start":{"line":1,"col